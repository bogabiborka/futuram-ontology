# sparql-llm config — copy to sparql-llm/.env and fill in.
#
# Backend: a LOCAL Ollama that transparently proxies to an Ollama CLOUD model.
# sparql-llm has no base_url field; LangChain's Ollama provider talks to the
# local daemon (OLLAMA_HOST), and Ollama itself routes the *-cloud model to the
# cloud. So sparql-llm only ever sees http://localhost:11434.
#
# Prereqs (once):
#   1. Install Ollama, then:  ollama signin           # link your ollama.com account
#   2. Pull/alias the cloud model so the local daemon can serve it, e.g.:
#        ollama pull deepseek-v4-pro:cloud
#   3. Daemon running:        ollama serve            # localhost:11434
#
# sparql-llm reads these via pydantic-settings (field name == env var, any case).

# The agent LLM, as "provider/model". provider=ollama -> LangChain ChatOllama
# (langchain-ollama) hitting the local daemon, which routes the :cloud tag to
# ollama.com. Other tags available: glm-5.1:cloud, qwen3.5:cloud,
# qwen3-coder-next:cloud, kimi-k2.6:cloud, gemma4:31b-cloud.
DEFAULT_LLM_MODEL=ollama/deepseek-v4-pro:cloud

# Where the local Ollama daemon listens (LangChain ChatOllama reads OLLAMA_HOST).
OLLAMA_HOST=http://localhost:11434

# CHAT_API_KEY is the key the sparql-llm web/MCP layer expects from callers; it
# is NOT the Ollama key. Local Ollama needs no key (the cloud auth lives in
# `ollama signin`, not here). Leave blank unless you front the app with auth.
CHAT_API_KEY=

# Embeddings run LOCALLY via fastembed — no API, no Ollama. Default is fine;
# override only to use a different local model.
# EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Local Qdrant for the RAG index (docker run -p 6333:6333 qdrant/qdrant).
# VECTORDB_URL=http://localhost:6333
