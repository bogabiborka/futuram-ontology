      [fq] a1 step 4 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\n\nSELECT DISTINCT ?cls ?label ?comment WHERE {\n  ?cls a owl:Class .\n  OPTIONAL { ?cls rdfs:label ?label }\n  OPTIONAL { ?cls rdfs:comment ?comment }\n  FILTER( CONTAINS(LCASE(STR(?label)), "wiring") ||\n          CONTAINS(LCASE(STR(?comment)), "wiring") ||\n          CONTAINS(LCASE(STR(?label)), "harness") ||\n          CONTAINS(LCASE(STR(?comment)), "harness") ||\n          CONTAINS(LCASE(STR(?label)), "cable") ||\n          CONTAINS(LCASE(STR(?comment)), "cable") ||\n          CONTAINS(LCASE(STR(?label)), "motor") ||\n          CONTAINS(LCASE(STR(?comment)), "motor") )\n}\nLIMIT 100')
      [fq] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Find scope nodes partOf the BEV segment C 2025 whole\nSELECT DISTINCT ?node ?type ?itemMass WHERE {\n  ?node futuram:partOf <https://www.purl.org/futuram#V0301030103_Y2025> ;\n        a ?type ;\n        fq:itemMass ?itemMass .\n}\nLIMIT 60')
      [fq] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Discover the Component root class\nSELECT DISTINCT ?root ?label WHERE {\n  ?root a <http://www.w3.org/2002/07/owl#Class> .\n  OPTIONAL { ?root rdfs:label ?label }\n  FILTER( CONTAINS(LCASE(STR(?label)), "component") )\n}\nLIMIT 30')
      [fq] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Show direct subclasses of the BEV segment C 2025 whole\nSELECT DISTINCT ?sub ?label WHERE {\n  ?sub rdfs:subClassOf <https://www.purl.org/futuram#V0301030103_Y2025> .\n  OPTIONAL { ?sub rdfs:label ?label }\n}\nLIMIT 50')
      [fq] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Read copper in motor, wiring (cables), and power electronics scopes within BEV seg-C 2025\nSELECT ?key ?itemMass ?frac ?unc WHERE {\n  VALUES ?key {\n    <https://www.purl.org/futuram#elvBEV_elvElectricMotor_Y2025>\n    <https://www.purl.org/futuram#elvBEV_elvEmbeddedElectronicsCables_Y2025>\n    <https://www.purl.org/futuram#elvBEV_elvPowerElectronics_Y2025>\n  }\n  ?node futuram:partOf <https://www.purl.org/futuram#V0301030103_Y2025> ;\n        a ?key ;\n        fq:itemMass ?itemMass ;\n        fq:contains [ fq:constituent <https://www.purl.org/futuram#Copper> ; fq:amount ?frac ; fq:relativeUncertainty ?unc ] .\n}\nORDER BY ?key') BLOCKED-bad-class
      [fq] a1 step 7 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Direct children of the BEV seg-C 2025 whole -> one row per direct component, copper kg each.\n# Discover the set via subClassOf closure (skip aggregates to avoid double-count).\nSELECT ?key (SAMPLE(?itemMass) AS ?m) (SAMPLE(?frac) AS ?f) (SAMPLE(?unc) AS ?u) WHERE {\n  ?node futuram:partOf <https://www.purl.org/futuram#V0301030103_Y2025> ;\n        a ?key ;\n        fq:itemMass ?itemMass ;\n        fq:contains [ fq:constituent <https://www.purl.org/futuram#Copper> ; fq:amount ?frac ; fq:relativeUncertainty ?unc ] .\n  ?key rdfs:subClassOf+ <https://www.purl.org/futuram#V0301030103_Y2025> .\n}\nGROUP BY ?key\nORDER BY (SAMPLE(?itemMass) * SAMPLE(?frac)) DESC')
      [fq] a1 step 8 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Per direct subclass of BEV seg-C 2025 whole, compute copper kg\nSELECT ?key (?m * ?f AS ?kg) (?f * ?m * ?u AS ?uncAbs) WHERE {\n  ?node futuram:partOf <https://www.purl.org/futuram#V0301030103_Y2025> ;\n        a ?key ;\n        fq:itemMass ?m ;\n        fq:contains [ fq:constituent <https://www.purl.org/futuram#Copper> ; fq:amount ?f ; fq:relativeUncertainty ?u ] .\n  ?key rdfs:subClassOf+ <https://www.purl.org/futuram#V0301030103_Y2025> .\n}\nORDER BY (?m * ?f) DESC')
