      [fq] a1 step 2 -> find_candidate_classes({"term": "battery electric vehicle 2025", "endpoint_url": "http://bench-fuseki:3030/query/sparql", "limit": 30})
      [fq] a1 step 2 -> find_candidate_classes({"term": "embedded electronics", "endpoint_url": "http://bench-fuseki:3030/query/sparql", "limit": 30})
      [fq] a1 step 3 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": '\nPREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Find the scope nodes of embedded electronics components inside the BEV 2025 standard\nSELECT ?node ?type ?typeLabel WHERE {\n  ?node futuram:partOf futuram:V0301030000_Y2025 .\n  ?node rdf:type ?type .\n  ?type rdfs:label ?typeLabel .\n  FILTER(CONTAINS(LCASE(STR(?typeLabel)), "embedded electronics"))\n}\nORDER BY ?typeLabel\n')
      [fq] a1 step 4 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": '\nPREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n\nSELECT ?node ?type ?typeLabel WHERE {\n  ?node futuram:partOf futuram:V0301030000_Y2025 .\n  ?node rdf:type ?type .\n  ?type rdfs:label ?typeLabel .\n  FILTER(CONTAINS(LCASE(STR(?typeLabel)), "embedded electronics"))\n}\nORDER BY ?typeLabel\n')
      [fq] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n\n# Check the aggregate embedded electronics node and its contains\nSELECT ?p ?o WHERE {\n  fq:elvEmbeddedElectronics_in_V0301030000_Y2025 ?p ?o .\n}\nLIMIT 60\n')
      [fq] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n\n# Check BEV-specific embedded electronics actuator node\nSELECT ?p ?o WHERE {\n  fq:elvBEV_elvEmbeddedElectronicsActuators_Y2025_in_V0301030000_Y2025 ?p ?o .\n}\nLIMIT 80\n')
      [fq] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX mw: <https://purl.org/metalwheel#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX chebi: <http://purl.obolibrary.org/obo/>\n\nSELECT ?constituent\n       (?frac * ?itemMass AS ?kg)\n       (?relUnc * ?frac * ?itemMass AS ?kgUnc)\n       ?chebi ?baseChebi ?proc ?eff ?importance ?year WHERE {\n  fq:elvEmbeddedElectronics_in_V0301030000_Y2025 fq:itemMass ?itemMass ;\n    fq:contains [ fq:constituent ?constituent ;\n                  fq:amount ?frac ;\n                  fq:relativeUncertainty ?relUnc ] .\n  ?constituent rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi),"CHEBI"))\n  OPTIONAL {\n    ?chebi crit:remark ?flag .\n    ?flag crit:importance ?importance ; crit:year ?year .\n  }\n  OPTIONAL {\n    ?chebi mw:hasRecoveryInformation ?ri .\n    ?ri mw:hasBaseMetal ?baseChebi ;\n        mw:hasRecoveryProcess ?proc ;\n        mw:hasExpectedRecoveryEffectiveness ?eff .\n  }\n}\nORDER BY ?constituent\n')
      [fq] a1 step 7 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX mw: <https://purl.org/metalwheel#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\n\n# CRM constituents in BEV 2025 embedded electronics, each with its own recovery route\nSELECT DISTINCT ?constituent ?chebi ?importance (?frac * ?itemMass AS ?kg) (?relUnc * ?frac * ?itemMass AS ?kgUnc) ?route ?eff WHERE {\n  fq:elvEmbeddedElectronics_in_V0301030000_Y2025 fq:itemMass ?itemMass ;\n    fq:contains [ fq:constituent ?constituent ;\n                  fq:amount ?frac ;\n                  fq:relativeUncertainty ?relUnc ] .\n  ?constituent rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi),"CHEBI"))\n  ?chebi crit:remark ?flag .\n  ?flag crit:importance ?importance .\n  # recovery slot: route where ?baseChebi is this element OR another co-present CRM\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseChebi ;\n      mw:hasRecoveryProcess ?route ;\n      mw:hasExpectedRecoveryEffectiveness ?eff .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n  # ensure the base metal is also a co-present CRM in this component\n  fq:elvEmbeddedElectronics_in_V0301030000_Y2025 fq:contains [ fq:constituent ?baseCrm ] .\n  ?baseCrm rdfs:subClassOf ?baseChebi . FILTER(CONTAINS(STR(?baseChebi),"CHEBI"))\n  ?baseChebi crit:remark ?baseFlag .\n}\nORDER BY ?constituent\n')
      [fq] a1 step 8 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX mw: <https://purl.org/metalwheel#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\n\n# Final: per CRM constituent, give one route (DISTINCT collapses duplicates for CRITICAL/STRATEGIC)\nSELECT DISTINCT ?constituent (SAMPLE(?kgVal) AS ?kg) (SAMPLE(?kgUncVal) AS ?kgUnc) (SAMPLE(?routeVal) AS ?route) WHERE {\n  fq:elvEmbeddedElectronics_in_V0301030000_Y2025 fq:itemMass ?itemMass ;\n    fq:contains [ fq:constituent ?constituent ;\n                  fq:amount ?frac ;\n                  fq:relativeUncertainty ?relUnc ] .\n  ?constituent rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi),"CHEBI"))\n  ?chebi crit:remark ?flag .\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseChebi ;\n      mw:hasRecoveryProcess ?routeVal ;\n      mw:hasExpectedRecoveryEffectiveness ?eff .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n  fq:elvEmbeddedElectronics_in_V0301030000_Y2025 fq:contains [ fq:constituent ?baseCrm ] .\n  ?baseCrm rdfs:subClassOf ?baseChebi . FILTER(CONTAINS(STR(?baseChebi),"CHEBI"))\n  ?baseChebi crit:remark ?baseFlag .\n  BIND(?frac * ?itemMass AS ?kgVal)\n  BIND(?relUnc * ?frac * ?itemMass AS ?kgUncVal)\n}\nGROUP BY ?constituent\nORDER BY ?constituent\n')
