      [fq] a1 step 7 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\nSELECT ?key ?keyLabel (?m * ?f AS ?kg) (?m AS ?itemMass_kg) (?f AS ?frac_kgPerKg) WHERE {\n  VALUES ?key {\n    <https://www.purl.org/futuram#elvElectricMotor>\n    <https://www.purl.org/futuram#elvEmbeddedElectronicsCables>\n    <https://www.purl.org/futuram#elvEmbeddedElectronics>\n    <https://www.purl.org/futuram#elvPowerElectronics>\n  }\n  ?node futuram:partOf <https://www.purl.org/futuram#V0301030103_Y2025> ;\n        rdf:type        ?key ;\n        fq:itemMass     ?m ;\n        fq:contains     [ fq:constituent <https://www.purl.org/futuram#Copper> ;\n                          fq:amount     ?f ] .\n  OPTIONAL { ?key rdfs:label ?keyLabel }\n}\nORDER BY DESC(?kg)') BLOCKED-bad-class
