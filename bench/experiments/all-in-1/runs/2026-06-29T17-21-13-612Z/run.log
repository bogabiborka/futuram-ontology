      [composition] a3 step 9 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nPREFIX afn: <http://jena.apache.org/ARQ/function#>\nSELECT ?el ?elLabel ?whole ?stmt ?pr ?val ?unit ?acc ?cmp ?con ?integ ?time ?valid ?itemMassVal ?itemMassUnit WHERE {\n  # the whole = Traction motor — permanent magnet\n  ?whole a ?wholeType .\n  ?wholeType rdfs:subClassOf* <https://www.purl.org/futuram#elvTractionMotorPM> .\n  # item mass\n  ?whole futuram:itemMass [ qudt:numericValue ?itemMassVal ; qudt:unit ?itemMassUnit ] .\n  # The part tree\n  ?whole futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr .\n  ?pr futuram:refersTo ?part .\n  ?pr futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?val ; qudt:unit ?unit ] .\n  OPTIONAL { ?pr dqv:hasQualityMeasurement/dqv:isMeasurementOf ?dim .\n             ?pr dqv:hasQualityMeasurement [ dqv:isMeasurementOf ?dim ; dqv:value ?score ] }\n  # Stop at the REE level (down to leaves that are ChEBI rare earth metal atoms)\n  ?part a ?el .\n  ?el rdfs:subClassOf* <http://purl.obolibrary.org/obo/CHEBI_33321> .\n}\nLIMIT 50')
