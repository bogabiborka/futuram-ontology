      [composition] a1 step 11 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?pr ?part ?label ?v ?u WHERE {\n  <https://www.purl.org/futuram/example#comp_V0401010102_2025> futuram:hasPartRelation ?pr .\n  ?pr futuram:refersTo ?part .\n  OPTIONAL { ?part rdfs:label ?label }\n  OPTIONAL { ?pr futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v ; qudt:unit ?u ] }\n}')
      [composition] a1 step 12 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX rdf:  <http://www.w3.org/2000/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX dqv:  <http://www.w3.org/ns/dqv#>\nSELECT ?cpath (SUM(?abs) AS ?totalKg) WHERE {\n  {\n    # Hop 1: top → component\n    ?mid1 futuram:refersTo ?comp .\n    ?pr1 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v1 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n    BIND(1 AS ?depth)\n  } UNION {\n    # Hop 2: component → material\n    ?comp futuram:hasCompositionStatement ?stmt2 .\n    ?stmt2 futuram:hasPartRelation ?pr2 .\n    ?pr2 futuram:refersTo ?mat ;\n         futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v2 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n    BIND(2 AS ?depth)\n  } UNION {\n    # Hop 3: material → element\n    ?mat futuram:hasCompositionStatement ?stmt3 .\n    ?stmt3 futuram:hasPartRelation ?pr3 .\n    ?pr3 futuram:refersTo ?elt ;\n         futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v3 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n    BIND(3 AS ?depth)\n  }\n  {\n    <https://www.purl.org/futuram/example#V0401010102_2025> futuram:hasCompositionStatement ?stmt1 .\n    ?stmt1 futuram:hasPartRelation ?pr1 .\n    ?pr1 futuram:refersTo ?comp .\n  }\n  ?elt rdf:type <https://www.purl.org/futuram#Copper> .\n  BIND(CONCAT(STR(?comp),"|",STR(?mat),"|",STR(?elt)) AS ?cpath)\n  BIND(?v1 * ?v2 * ?v3 * 1583.812 AS ?abs)\n} GROUP BY ?cpath\nORDER BY DESC(?totalKg)')
