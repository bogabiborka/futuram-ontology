      [composition] a2 step 13 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX afn: <http://jena.apache.org/ARQ/function#>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nSELECT (SUM(?alKg) AS ?totalAlKg)\n       (afn:sqrt(SUM(?alKg * ?alKg * ?uncRel * ?uncRel)) AS ?totalUncKg)\nWHERE {\n  {\n    SELECT ?pr1 ?pr2 ?pr3 (xsd:double(?v1) * xsd:double(?v2) * xsd:double(?v3) * 1337.383 AS ?alKg)\n           (xsd:double(?limit) / 1.7320508 AS ?uncRel)\n    WHERE {\n      <https://www.purl.org/futuram/example#V0201020102_2025> futuram:hasCompositionStatement ?st1 .\n      ?st1 futuram:hasPartRelation ?pr1 .\n      ?pr1 futuram:refersTo <https://www.purl.org/futuram/example#elvGeneralComponents__V0201020102_2025> ;\n           futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v1 ] .\n      <https://www.purl.org/futuram/example#elvGeneralComponents__V0201020102_2025> futuram:hasCompositionStatement ?st2 .\n      ?st2 futuram:hasPartRelation ?pr2 .\n      ?pr2 futuram:refersTo ?alloy ;\n           futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v2 ] .\n      FILTER(?alloy IN (\n        <https://www.purl.org/futuram/example#elvGeneralComponents_castAlAlloys__V0201020102>,\n        <https://www.purl.org/futuram/example#elvGeneralComponents_5xxxAlAlloy__V0201020102>,\n        <https://www.purl.org/futuram/example#elvGeneralComponents_2xxxAlAlloy__V0201020102>,\n        <https://www.purl.org/futuram/example#elvGeneralComponents_6xxxAlAlloy__V0201020102>\n      ))\n      ?alloy futuram:hasCompositionStatement ?st3 .\n      ?st3 futuram:hasPartRelation ?pr3 .\n      ?pr3 futuram:refersTo ?alElem ;\n           futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v3 ] .\n      FILTER(STRENDS(STR(?alElem), "_Al__V0201020102"))\n      {\n        SELECT ?pr1 ?pr2 ?pr3 ?limit WHERE {\n          ?pr1 dqv