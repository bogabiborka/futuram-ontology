      [fq] a1 step 3 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Show the components scoped to this whole + their own compositions\nSELECT DISTINCT ?node ?type ?label ?itemMass WHERE {\n  ?node futuram:partOf futuram:V0301030104_Y2020 ;\n        rdf:type ?type ;\n        fq:itemMass ?itemMass .\n  OPTIONAL { ?type rdfs:label ?label }\n} ORDER BY DESC(?itemMass)')
      [fq] a1 step 4 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\n\n# Find all components (direct) of the BEV segment D 2020 whole, excluding battery\nSELECT DISTINCT ?comp ?label WHERE {\n  ?comp rdfs:subClassOf* futuram:Component .\n  ?comp rdfs:label ?label .\n  FILTER(CONTAINS(LCASE(STR(?label)), "battery"))\n}\nLIMIT 50')
      [fq] a1 step 4 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Find DIRECT components of the whole (one rdfs:subClassOf step below the level root)\nSELECT DISTINCT ?comp ?label WHERE {\n  ?comp rdfs:subClassOf futuram:Component .\n  ?comp rdfs:label ?label .\n}\nORDER BY ?label')
      [fq] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Find direct component classes (level-root direct subs), excluding the ones that are sub-classes\n# Also check battery\nSELECT DISTINCT ?comp ?label WHERE {\n  ?comp rdfs:subClassOf futuram:Component .\n  ?comp rdfs:label ?label .\n  FILTER NOT EXISTS {\n    ?comp rdfs:subClassOf ?mid .\n    ?mid rdfs:subClassOf futuram:Component .\n    FILTER(?mid != futuram:Component)\n  }\n}\nORDER BY ?label')
      [fq] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Find the components DIRECTLY under this whole (one subClassOf step below the level root)\n# using the type hierarchy, NOT the scope node (to avoid stacking)\nSELECT DISTINCT ?comp ?label WHERE {\n  ?comp rdfs:subClassOf futuram:Component .\n  ?comp rdfs:label ?label .\n  FILTER NOT EXISTS {\n    ?comp rdfs:subClassOf ?mid .\n    ?mid rdfs:subClassOf futuram:Component .\n    FILTER(?mid != futuram:Component)\n  }\n}\nORDER BY ?label')
      [fq] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Look for a "battery" class in the ontology\nSELECT DISTINCT ?comp ?label WHERE {\n  ?comp rdfs:label ?label .\n  FILTER(LANG(?label) = "en" || LANG(?label) = "")\n  FILTER(CONTAINS(LCASE(STR(?label)), "battery"))\n}\nORDER BY ?label\nLIMIT 50')
      [fq] a1 step 7 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n# Search by local name for battery or power storage classes\nSELECT DISTINCT ?cls ?label WHERE {\n  ?cls a owl:Class .\n  ?cls rdfs:label ?label .\n  FILTER(\n    CONTAINS(LCASE(STR(?label)), "battery")\n    || CONTAINS(LCASE(STR(?label)), "energy storage")\n    || CONTAINS(LCASE(STR(?label)), "power pack")\n  )\n}\nORDER BY ?label\nLIMIT 40')
      [fq] a1 step 7 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\n\n# Look for any class in the components hierarchy with battery in its local name\nSELECT DISTINCT ?cls ?label WHERE {\n  ?cls a owl:Class .\n  OPTIONAL { ?cls rdfs:label ?label }\n  FILTER(CONTAINS(LCASE(STR(?cls)), "battery") || CONTAINS(LCASE(STR(?cls)), "elvBat") || CONTAINS(LCASE(STR(?cls)), "elvRechargeable"))\n}\nLIMIT 40') BLOCKED-bad-class
