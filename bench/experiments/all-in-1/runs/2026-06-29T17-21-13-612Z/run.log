      [composition] a3 step 14 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl:  <http://www.w3.org/2002/07/owl#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nSELECT ?inst ?itemMass ?uMass WHERE {\n  ?inst a futuram:V0401010102 .\n  ?inst futuram:itemMass ?massNode .\n  ?massNode qudt:numericValue ?itemMass ;\n            qudt:unit ?uMass .\n}\nLIMIT 10')
      [composition] a3 step 15 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl:  <http://www.w3.org/2002/07/owl#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nSELECT ?alloyClass ?alloyLabel ?frac ?unit ?itemMass WHERE {\n  BIND( futuram:V0401010102_2020 AS ?inst )\n  ?inst futuram:itemMass [ qudt:numericValue ?itemMass ] .\n  ?inst futuram:hasCompositionStatement/futuram:hasPartRelation/futuram:refersTo ?part .\n  ?part a ?alloyClass .\n  ?alloyClass rdfs:subClassOf* futuram:AlAndAlAlloys .\n  ?alloyClass rdfs:label ?alloyLabel .\n  ?pr futuram:refersTo ?part ;\n      futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?frac ; qudt:unit ?unit ] .\n  ?inst futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr .\n}\nLIMIT 200')
      [composition] a3 step 16 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl:  <http://www.w3.org/2002/07/owl#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?part ?frac ?unit WHERE {\n  ?inst futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr .\n  ?pr futuram:refersTo ?part ;\n     futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?frac ; qudt:unit ?unit ] .\n  VALUES ?inst { <https://www.purl.org/futuram/example#V0401010102_2020> }\n}\nLIMIT 200')
      [composition] a3 step 17 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl:  <http://www.w3.org/2002/07/owl#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX afn: <http://jena.apache.org/ARQ/function#>\nSELECT ?alloyCls ?alloyLabel (SUM(?kg) AS ?totalKg) WHERE {\n  ?whole futuram:itemMass [ qudt:numericValue ?itemMass ] .\n  VALUES ?whole { <https://www.purl.org/futuram/example#V0401010102_2020> }\n  ?whole futuram:hasCompositionStatement ?stmt1 .\n  ?stmt1 futuram:hasPartRelation/futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f1 ; qudt:unit unit:KiloGM-PER-KiloGM ] .\n  ?stmt1 futuram:hasPartRelation/futuram:refersTo ?mid .\n  ?mid futuram:hasCompositionStatement ?stmt2 .\n  ?stmt2 futuram:hasPartRelation/futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f2 ; qudt:unit unit:KiloGM-PER-KiloGM ] .\n  ?stmt2 futuram:hasPartRelation/futuram:refersTo ?alloyInst .\n  ?alloyInst a ?alloyCls .\n  ?alloyCls rdfs:subClassOf* futuram:AlAndAlAlloys .\n  ?alloyCls rdfs:label ?alloyLabel .\n  BIND((?f1 * ?f2 * ?itemMass) AS ?kg)\n}\nGROUP BY ?alloyCls ?alloyLabel\nORDER BY DESC(?totalKg)')
      [composition] a3 step 18 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?alloyCls ?alloyLabel (SUM(?f1 * ?f2 * 1531.887) AS ?totalKg) WHERE {\n  BIND(<https://www.purl.org/futuram/example#V0401010102_2020> AS ?whole)\n  ?whole futuram:hasCompositionStatement ?stmt1 .\n  ?stmt1 futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?mid ;\n        futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f1 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?mid futuram:hasCompositionStatement ?stmt2 .\n  ?stmt2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?alloyInst ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f2 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?alloyInst a ?alloyCls .\n  ?alloyCls rdfs:subClassOf* futuram:AlAndAlAlloys .\n  ?alloyCls rdfs:label ?alloyLabel .\n}\nGROUP BY ?alloyCls ?alloyLabel\nORDER BY DESC(?totalKg)')
