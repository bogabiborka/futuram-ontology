      [composition] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nSELECT ?cls ?label WHERE {\n  ?cls rdfs:label ?label .\n  FILTER(CONTAINS(LCASE(STR(?label)), "2025"))\n  FILTER(CONTAINS(LCASE(STR(?label)), "bev") || CONTAINS(LCASE(STR(?label)), "battery") || CONTAINS(LCASE(STR(?label)), "standard"))\n} LIMIT 20')
      [composition] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nSELECT ?cls ?label WHERE {\n  ?cls rdfs:label ?label .\n  FILTER(CONTAINS(LCASE(STR(?label)), "2025"))\n} LIMIT 50')
      [composition] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nSELECT ?cls ?label ?parent WHERE {\n  ?cls rdfs:label ?label .\n  FILTER(CONTAINS(STR(?label), "V0301030000_2025"))\n  OPTIONAL { ?cls rdfs:subClassOf ?parent }\n}')
      [composition] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nSELECT ?stmt ?pr ?part ?v ?u WHERE {\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr .\n  ?pr futuram:refersTo ?part .\n  ?pr futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v ; qudt:unit ?u ] .\n} LIMIT 50')
      [composition] a1 step 7 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX mw: <https://purl.org/metalwheel#>\nPREFIX unit: <http://qudt.org/vocab/unit/>\n\nSELECT ?nodeLabel ?partLabel ?element ?f ?m ?baseMetal ?route ?eff WHERE {\n  # bind the standard BEV 2025 whole instance\n  ?whole a <https://www.purl.org/futuram#V0301030000> ;\n         futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?mid1 ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f1 ; qudt:unit ?u1 ] .\n  # mid1 is one of the embedded electronics subcomponents\n  ?mid1 a ?mid1Class .\n  FILTER(?mid1Class IN (<https://www.purl.org/futuram#elvEmbeddedElectronicsActuators>,\n                       <https://www.purl.org/futuram#elvEmbeddedElectronicsCables>,\n                       <https://www.purl.org/futuram#elvEmbeddedElectronicsControllers>,\n                       <https://www.purl.org/futuram#elvEmbeddedElectronicsHeadlights>))\n  # mid1 -> element hop\n  ?mid1 futuram:hasCompositionStatement ?stmt2 .\n  ?stmt2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?element ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f2 ; qudt:unit ?u2 ] .\n  ?element rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi), "CHEBI"))\n  ?chebi crit:remark ?flag . ?flag crit:importance ?imp .\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasExpectedRecoveryEffectiveness ?eff ;\n      mw:hasRecoveryProcess ?route .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n  # whole\'s mass\n  ?whole futuram:itemMass [ qudt:numericValue ?m ; qudt:unit ?mu ] .\n  BIND((?f1 * ?f2 * ?m) AS ?f)\n  BIND(?mid1Class AS ?nodeLabel)\n  BIND(STR(?mid1) AS ?partLabel)\n} LIMIT 50') BLOCKED-bad-class
      [composition] a1 step 8 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX mw: <https://purl.org/metalwheel#>\n\n# First: find the children of elvEmbeddedElectronics (the group)\nSELECT ?sub ?label WHERE {\n  ?sub rdfs:subClassOf <https://www.purl.org/futuram#elvEmbeddedElectronics> .\n  OPTIONAL { ?sub rdfs:label ?label }\n}')
      [composition] a1 step 8 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?stmt ?pr ?part ?v ?u WHERE {\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr .\n  ?pr futuram:refersTo ?part ;\n      futuram:hasQuantity/futuram:hasBestValue ?bv .\n  ?bv qudt:numericValue ?v ; qudt:unit ?u .\n} LIMIT 50')
      [composition] a1 step 9 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?m ?u WHERE {\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:itemMass [ qudt:numericValue ?m ; qudt:unit ?u ] .\n}')
      [composition] a1 step 9 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?part ?v ?u WHERE {\n  <https://www.purl.org/futuram/example#elvEmbeddedElectronicsControllers__V0301030000_2025> futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr .\n  ?pr futuram:refersTo ?part ;\n      futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v ; qudt:unit ?u ] .\n} LIMIT 30')
      [composition] a1 step 10 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX mw: <https://purl.org/metalwheel#>\n\n# Walk all embedded electronics subcomponents: BEV2025 -> elvEmbeddedElectronics* subcomponents -> their elements\n# Get critical elements and metal-wheel routes\nSELECT ?mid1 ?mid2 ?element ?f1 ?f2 ?baseMetal ?route ?eff ?imp ?year WHERE {\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:hasCompositionStatement ?stmt1 .\n  ?stmt1 futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?mid1 ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f1 ; qudt:unit ?u1 ] .\n  # mid1 must be one of the embedded electronics subcomponents\n  ?mid1 a ?mid1Type .\n  ?mid1Type rdfs:subClassOf* <https://www.purl.org/futuram#elvEmbeddedElectronics> .\n  FILTER(?mid1Type != <https://www.purl.org/futuram#elvEmbeddedElectronics>)\n  # Now walk one more hop: mid1 -> ?mid2 (e.g. PCBelectronics) \n  ?mid1 futuram:hasCompositionStatement ?stmt2 .\n  ?stmt2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?mid2 ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f2 ; qudt:unit ?u2 ] .\n  # Now walk to element leaf: ?mid2 -> ?element\n  ?mid2 futuram:hasCompositionStatement ?stmt3 .\n  ?stmt3 futuram:hasPartRelation ?pr3 .\n  ?pr3 futuram:refersTo ?element ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f3 ; qudt:unit ?u3 ] .\n  # Element must be critical\n  ?element rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi), "CHEBI"))\n  ?chebi crit:remark ?flag . ?flag crit:importance ?imp . OPTIONAL { ?flag crit:year ?year }\n  # Metal-wheel\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasExpectedRecoveryEffectiveness ?eff ;\n      mw:hasRecoveryProcess ?route .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n} LIMIT 30')
      [composition] a1 step 11 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX mw: <https://purl.org/metalwheel#>\n\n# Compute kg mass of each embedded electronics subcomponent in the BEV 2025 whole\n# and join critical + metal-wheel for each\nSELECT ?eeClass ?kg ?baseMetal ?route WHERE {\n  # whole mass\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:itemMass [ qudt:numericValue ?m ; qudt:unit unit:KiloGM ] .\n  # parts of the whole that are embedded electronics\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr .\n  ?pr futuram:refersTo ?ee ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f ; qudt:unit unit:KiloGM-PER-KiloGM ] .\n  # discover the group via subclass (no hand-listing)\n  ?ee a ?eeType .\n  ?eeType rdfs:subClassOf* <https://www.purl.org/futuram#elvEmbeddedElectronics> .\n  FILTER(?eeType != <https://www.purl.org/futuram#elvEmbeddedElectronics>)\n  BIND(?m * ?f AS ?kg)\n  # metal-wheel: routes the whole embedded electronics subcomponent material goes through\n  ?eeType rdfs:subClassOf* ?chebi . FILTER(CONTAINS(STR(?chebi), "CHEBI"))\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasExpectedRecoveryEffectiveness ?eff ;\n      mw:hasRecoveryProcess ?route .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n  BIND(STRAFTER(STR(?eeType), "#") AS ?eeClass)\n} ORDER BY ?eeType ?baseMetal')
      [composition] a1 step 12 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX mw: <https://purl.org/metalwheel#>\n\nSELECT ?eeType ?kg ?baseMetal ?route WHERE {\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:itemMass [ qudt:numericValue ?m ; qudt:unit <http://qudt.org/vocab/unit/KiloGM> ] .\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr .\n  ?pr futuram:refersTo ?ee ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?ee a ?eeType .\n  ?eeType rdfs:subClassOf* <https://www.purl.org/futuram#elvEmbeddedElectronics> .\n  FILTER(?eeType != <https://www.purl.org/futuram#elvEmbeddedElectronics>)\n  BIND(?m * ?f AS ?kg)\n  ?eeType rdfs:subClassOf* ?chebi . FILTER(CONTAINS(STR(?chebi), "CHEBI"))\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasExpectedRecoveryEffectiveness ?eff ;\n      mw:hasRecoveryProcess ?route .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n} ORDER BY ?eeType ?baseMetal')
      [composition] a1 step 13 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX mw: <https://purl.org/metalwheel#>\n\n# Walk BEV 2025 -> EE subcomponents -> their elements, filter to critical + metal-wheel\nSELECT ?eeType ?element ?kgEE ?fEl ?baseMetal ?route ?imp WHERE {\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:itemMass [ qudt:numericValue ?m ; qudt:unit <http://qudt.org/vocab/unit/KiloGM> ] .\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:hasCompositionStatement ?stmt1 .\n  ?stmt1 futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?ee ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f1 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?ee a ?eeType .\n  ?eeType rdfs:subClassOf* <https://www.purl.org/futuram#elvEmbeddedElectronics> .\n  FILTER(?eeType != <https://www.purl.org/futuram#elvEmbeddedElectronics>)\n  BIND(?m * ?f1 AS ?kgEE)\n  # 2nd hop: EE subcomponent -> material/element\n  ?ee futuram:hasCompositionStatement ?stmt2 .\n  ?stmt2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?mid2 ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f2 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  # 3rd hop: mid2 -> element\n  ?mid2 futuram:hasCompositionStatement ?stmt3 .\n  ?stmt3 futuram:hasPartRelation ?pr3 .\n  ?pr3 futuram:refersTo ?element ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f3 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  # element class -> ChEBI -> critical\n  ?element rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi), "CHEBI"))\n  ?chebi crit:remark ?flag . ?flag crit:importance ?imp .\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasExpectedRecoveryEffectiveness ?eff ;\n      mw:hasRecoveryProcess ?route .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n  BIND(?f3 AS ?fEl)\n} ORDER BY ?eeType ?element ?baseMetal')
      [composition] a1 step 14 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?mid2 ?v ?u WHERE {\n  <https://www.purl.org/futuram/example#elvEmbeddedElectronicsCables__V0301030000_2025> futuram:hasCompositionStatement ?stmt2 .\n  ?stmt2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?mid2 ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v ; qudt:unit ?u ] .\n} LIMIT 30')
      [composition] a1 step 15 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX mw: <https://purl.org/metalwheel#>\n\n# Walk 4 hops: BEV -> EE -> mid2 -> mid3 -> element, filter to critical + metal-wheel\nSELECT ?eeType ?element ?fEE ?fMid2 ?fMid3 ?fEl ?baseMetal ?route ?imp WHERE {\n  <https://www.purl.org/futuram/example#V0301030000_2025> futuram:hasCompositionStatement ?stmt1 .\n  ?stmt1 futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?ee ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f1 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?ee a ?eeType .\n  ?eeType rdfs:subClassOf* <https://www.purl.org/futuram#elvEmbeddedElectronics> .\n  FILTER(?eeType != <https://www.purl.org/futuram#elvEmbeddedElectronics>)\n  BIND(?f1 AS ?fEE)\n  ?ee futuram:hasCompositionStatement ?stmt2 .\n  ?stmt2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?mid2 ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f2 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  BIND(?f2 AS ?fMid2)\n  ?mid2 futuram:hasCompositionStatement ?stmt3 .\n  ?stmt3 futuram:hasPartRelation ?pr3 .\n  ?pr3 futuram:refersTo ?mid3 ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f3 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  BIND(?f3 AS ?fMid3)\n  ?mid3 futuram:hasCompositionStatement ?stmt4 .\n  ?stmt4 futuram:hasPartRelation ?pr4 .\n  ?pr4 futuram:refersTo ?element ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?f4 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  BIND(?f4 AS ?fEl)\n  ?element rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi), "CHEBI"))\n  ?chebi crit:remark ?flag . ?flag crit:importance ?imp .\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasExpectedRecoveryEffectiveness ?eff ;\n      mw:hasRecoveryProcess ?route .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n} ORDER BY ?eeType ?element ?baseMetal')
      [composition] a1 step 16 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?mid3 ?v ?u ?type WHERE {\n  <https://www.purl.org/futuram/example#elvEmbeddedElectronicsCables_pureCu__V0301030000> futuram:hasCompositionStatement ?stmt3 .\n  ?stmt3 futuram:hasPartRelation ?pr3 .\n  ?pr3 futuram:refersTo ?mid3 ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v ; qudt:unit ?u ] .\n  OPTIONAL { ?mid3 a ?type }\n} LIMIT 30')
