      [fq] a1 step 8 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX afn:     <http://jena.apache.org/ARQ/function#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nSELECT ?componentLabel ?kg ?sigmaABS WHERE {\n  VALUES ?component {\n    futuram:elvBEV_elvElectricMotor_Y2025\n    futuram:elvBEV_elvEmbeddedElectronicsCables_Y2025\n    futuram:elvBEV_elvEmbeddedElectronicsControllers_Y2025\n    futuram:elvBEV_elvEmbeddedElectronicsActuators_Y2025\n    futuram:elvBEV_elvEmbeddedElectronicsHeadlights_Y2025\n    futuram:elvBEV_elvPowerElectronics_Y2025\n  }\n  ?component rdfs:label ?componentLabel .\n  ?component fq:itemMass ?itemMass ;\n             fq:contains [ fq:constituent futuram:Copper ;\n                           fq:amount ?frac ;\n                           fq:relativeUncertainty ?relUnc ] .\n  BIND(?frac * ?itemMass AS ?kg)\n  BIND(?relUnc * ?frac * ?itemMass AS ?sigmaABS)\n}\nORDER BY ?componentLabel') BLOCKED-bad-class
      [fq] a1 step 9 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX afn:     <http://jena.apache.org/ARQ/function#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nSELECT ?component ?componentLabel ?kg ?sigmaABS WHERE {\n  ?component fq:itemMass ?itemMass .\n  ?component fq:contains [ fq:constituent futuram:Copper ;\n                          fq:amount ?frac ;\n                          fq:relativeUncertainty ?relUnc ] .\n  ?component rdfs:label ?componentLabel .\n  # restrict to the BEV 2025 segment-C components by matching the IRI pattern\n  FILTER(STRSTARTS(STR(?component), "https://www.purl.org/futuram#elvBEV_") &&\n         STRENDS(STR(?component), "_Y2025"))\n  BIND(?frac * ?itemMass AS ?kg)\n  BIND(?relUnc * ?frac * ?itemMass AS ?sigmaABS)\n}\nORDER BY ?component')
