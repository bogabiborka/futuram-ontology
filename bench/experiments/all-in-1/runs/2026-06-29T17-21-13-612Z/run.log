      [composition] a1 step 9 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nSELECT DISTINCT ?inst ?label WHERE {\n  ?inst rdf:type futuram:V0301030000 .\n  OPTIONAL { ?inst rdfs:label ?label }\n} LIMIT 30')
      [composition] a1 step 10 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX mw: <https://purl.org/metalwheel#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\n\nSELECT ?whole ?embInst ?embClass ?embMass ?u_embMass ?element ?elClass ?baseMetal ?route ?eff ?partMass ?partFraction ?partUnit WHERE {\n  BIND(<https://www.purl.org/futuram/example#V0301030000_2025> AS ?whole)\n\n  # whole itemMass\n  ?whole futuram:itemMass [ qudt:numericValue ?wholeMass ; qudt:unit ?u_wholeMass ] .\n\n  # hop 1: whole -> embeddedElectronics (component)\n  ?whole futuram:hasCompositionStatement ?st1 .\n  ?st1 futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?embInst ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?fracEE ; qudt:unit ?uEE ] .\n  ?embInst rdf:type <https://www.purl.org/futuram#elvEmbeddedElectronics> .\n\n  BIND( (?wholeMass * ?fracEE) AS ?embMass )\n  FILTER(?u_wholeMass = qudt:KiloGM || CONTAINS(STR(?u_wholeMass), "KiloGM"))\n\n  # hop 2: embeddedElectronics -> materials -> elements  (one or two hops)\n  ?embInst futuram:hasCompositionStatement ?st2 .\n  ?st2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?midPart ;\n       futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?fracMid ; qudt:unit ?uMid ] .\n\n  # mid part may be a material (then another hop) or directly an element\n  OPTIONAL {\n    ?midPart futuram:hasCompositionStatement ?st3 .\n    ?st3 futuram:hasPartRelation ?pr3 .\n    ?pr3 futuram:refersTo ?element ;\n         futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?fracElem ; qudt:unit ?uElem ] .\n    ?element rdf:type ?elClass .\n  }\n  # if mid is itself the element:\n  OPTIONAL {\n    FILTER NOT EXISTS { ?midPart futuram:hasCompositionStatement ?st3 }\n    BIND(?midPart AS ?element)\n    BIND(?fracMid AS ?fracElem)\n    BIND(?uMid AS ?uElem)\n    ?element rdf:type ?elClass .\n  }\n\n  # recovery routes via ChEBI\n  ?elClass rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi), "CHEBI"))\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasExpectedRecoveryEffectiveness ?eff ;\n      mw:hasRecoveryProcess ?route .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n  FILTER(?eff != mw:RecoveredInAlloyCompoundOrLost)\n\n  BIND(?embMass AS ?embMassOut)\n} LIMIT 100')
      [composition] a1 step 11 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX mw: <https://purl.org/metalwheel#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nPREFIX afn: <http://jena.apache.org/ARQ/function#>\n\nSELECT ?elClass ?baseMetal ?route ?eff\n       (SUM(?elementKg) AS ?totalKg)\n       (afn:sqrt(SUM(?sigmaSq)) AS ?totalSigma)\nWHERE {\n  {\n    SELECT ?elClass ?baseMetal ?route ?eff ?embInst ?pr2 ?midPr1Frac (xsd:double(?embMassOut)*xsd:double(?midFrac)*xsd:double(?leafFrac) AS ?elementKg) WHERE {\n      BIND(<https://www.purl.org/futuram/example#V0301030000_2025> AS ?whole)\n      ?whole futuram:itemMass [ qudt:numericValue ?wholeMass ; qudt:unit ?u_wholeMass ] .\n      FILTER(?u_wholeMass = qudt:KiloGM)\n      ?whole futuram:hasCompositionStatement ?st1 .\n      ?st1 futuram:hasPartRelation ?pr1 .\n      ?pr1 futuram:refersTo ?embInst ;\n           futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?fracEE ; qudt:unit ?uEE ] .\n      ?embInst rdf:type <https://www.purl.org/futuram#elvEmbeddedElectronics> .\n      BIND((xsd:double(?wholeMass)*xsd:double(?fracEE)) AS ?embMassOut)\n\n      ?embInst futuram:hasCompositionStatement ?st2 .\n      ?st2 futuram:hasPartRelation ?pr2 .\n      ?pr2 futuram:refersTo ?midPart ;\n           futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?fracMid ; qudt:unit ?uMid ] .\n      BIND(xsd:double(?fracMid) AS ?midFrac)\n\n      OPTIONAL {\n        ?midPart futuram:hasCompositionStatement ?st3 .\n        ?st3 futuram:hasPartRelation ?pr3 .\n        ?pr3 futuram:refersTo ?leafPart ;\n             futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?fracElem ; qudt:unit ?uElem ]