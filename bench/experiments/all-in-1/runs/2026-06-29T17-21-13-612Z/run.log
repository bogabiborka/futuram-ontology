      [composition] a1 step 14 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?part ?v ?u WHERE {\n  BIND(<https://www.purl.org/futuram/example#elvGeneralComponents__V0301030000_2020> AS ?mid)\n  ?mid futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr .\n  ?pr futuram:refersTo ?part .\n  ?pr futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v ; qudt:unit ?u ] .\n}')
      [composition] a1 step 14 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?itemMass WHERE {\n  BIND(<https://www.purl.org/futuram/example#V0301030000_2020> AS ?whole)\n  ?whole futuram:itemMass ?im .\n  ?im qudt:numericValue ?itemMass .\n  ?im qudt:unit ?u .\n}')
      [composition] a1 step 15 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nSELECT ?whole ?v1 ?v2 ?itemMass (?itemMass * ?v1 * ?v2 AS ?kg) WHERE {\n  ?whole a ?segClass .\n  ?segClass rdfs:subClassOf <https://www.purl.org/futuram#elvBEV> .\n  ?segClass rdfs:subClassOf ?parent .\n  FILTER(?parent = <https://www.purl.org/futuram#elvBEV>)\n  FILTER(STRENDS(STR(?whole), "_2020"))\n  ?whole futuram:hasCompositionStatement ?st1 .\n  ?st1 futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?mid .\n  ?mid a <https://www.purl.org/futuram#elvGeneralComponents> .\n  ?pr1 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v1 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?mid futuram:hasCompositionStatement ?st2 .\n  ?st2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?leaf .\n  ?leaf a/rdfs:subClassOf* <https://www.purl.org/futuram#5xxxAlAlloy> .\n  ?pr2 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v2 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?whole futuram:itemMass [ qudt:numericValue ?itemMass ; qudt:unit <http://qudt.org/vocab/unit/KiloGM> ] .\n}\nORDER BY DESC(?kg)')
      [composition] a1 step 16 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nSELECT ?whole ?pr1 ?v1 ?pr2 ?v2 ?s1 ?s2 WHERE {\n  ?whole a ?segClass .\n  ?segClass rdfs:subClassOf <https://www.purl.org/futuram#elvBEV> .\n  ?whole futuram:hasCompositionStatement ?st1 .\n  ?st1 futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?mid .\n  ?mid a <https://www.purl.org/futuram#elvGeneralComponents> .\n  ?pr1 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v1 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?mid futuram:hasCompositionStatement ?st2 .\n  ?st2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?leaf .\n  ?leaf a/rdfs:subClassOf* <https://www.purl.org/futuram#5xxxAlAlloy> .\n  ?pr2 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v2 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?pr1 dqv:hasQualityMeasurement/dqv:value ?s1 .\n  ?pr2 dqv:hasQualityMeasurement/dqv:value ?s2 .\n  FILTER(STRENDS(STR(?whole), "_2020"))\n}\nLIMIT 200')
      [composition] a1 step 17 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nSELECT ?whole ?pr ?dim ?score WHERE {\n  ?whole a ?segClass .\n  ?segClass rdfs:subClassOf <https://www.purl.org/futuram#elvBEV> .\n  FILTER(STRENDS(STR(?whole), "_2020"))\n  ?whole futuram:hasCompositionStatement ?st1 .\n  ?st1 futuram:hasPartRelation ?pr .\n  ?pr futuram:refersTo ?mid .\n  ?mid a <https://www.purl.org/futuram#elvGeneralComponents> .\n  ?mid futuram:hasCompositionStatement ?st2 .\n  ?st2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?leaf .\n  ?leaf a/rdfs:subClassOf* <https://www.purl.org/futuram#5xxxAlAlloy> .\n  ?pr2 dqv:hasQualityMeasurement ?qm .\n  ?qm dqv:isMeasurementOf ?dim .\n  ?qm dqv:value ?score .\n} ORDER BY ?whole ?pr ?dim\nLIMIT 200')
      [composition] a1 step 18 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX afn: <http://jena.apache.org/ARQ/function#>\nSELECT ?whole ?kg\n       (?itemMass * ?v1 * ?v2 AS ?kgValue)\n       ((?v1 * ?v2) * ?itemMass * ?limit / 1.7320508 AS ?sigmaValue)\nWHERE {\n  ?whole a ?segClass .\n  ?segClass rdfs:subClassOf <https://www.purl.org/futuram#elvBEV> .\n  FILTER(STRENDS(STR(?whole), "_2020"))\n  ?whole futuram:hasCompositionStatement ?st1 .\n  ?st1 futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?mid .\n  ?mid a <https://www.purl.org/futuram#elvGeneralComponents> .\n  ?pr1 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v1 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?mid futuram:hasCompositionStatement ?st2 .\n  ?st2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?leaf .\n  ?leaf a/rdfs:subClassOf* <https://www.purl.org/futuram#5xxxAlAlloy> .\n  ?pr2 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v2 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?whole futuram:itemMass [ qudt:numericValue ?itemMass ; qudt:unit <http://qudt.org/vocab/unit/KiloGM> ] .\n  # combine uncertainties of the two hops by RSS (in absolute)\n  {\n    SELECT ?pr1 (?limit AS ?limit1) WHERE {\n      ?pr1 dqv:hasQualityMeasurement ?qm1 .\n      ?qm1 dqv:isMeasurementOf ?dim1 .\n      ?qm1 dqv:value ?s1 .\n      {\n        SELECT ?pr1 (SUM(?w*?s) AS ?wsum) WHERE {\n          ?pr1 dqv:hasQualityMeasurement ?qm .\n          ?qm dqv:isMeasurementOf ?dim .\n          ?qm dqv:value ?s .\n          BIND(IF(?dim = <https://www.purl.org/futuram#IntegrityScore>, 0.5, IF(?dim = <https://www.purl.org/futuram#TimelinessScore>, 1.5, 1.0)) AS ?w)\n        } GROUP BY ?pr1\n      }\n      BIND(IF(?wsum < 7, 0.10, IF(?wsum < 9, 0.15, IF(?wsum < 10, 0.20, IF(?wsum < 14, 0.25, IF(?wsum < 15, 0.30, 0.35))))) AS ?limit)\n    }\n  }\n  {\n    SELECT ?pr2 (?limit AS ?limit2) WHERE {\n      ?pr2 dqv:hasQualityMeasurement ?qm2 .\n      ?qm2 dqv:isMeasurementOf ?dim2 .\n      ?qm2 dqv:value ?s2 .\n      {\n        SELECT ?pr2 (SUM(?w*?s) AS ?wsum) WHERE {\n          ?pr2 dqv:hasQualityMeasurement ?qm .\n          ?qm dqv:isMeasurementOf ?dim .\n          ?qm dqv:value ?s .\n          BIND(IF(?dim = <https://www.purl.org/futuram#IntegrityScore>, 0.5, IF(?dim = <https://www.purl.org/futuram#TimelinessScore>, 1.5, 1.0)) AS ?w)\n        } GROUP BY ?pr2\n      }\n      BIND(IF(?wsum < 7, 0.10, IF(?wsum < 9, 0.15, IF(?wsum < 10, 0.20, IF(?wsum < 14, 0.25, IF(?wsum < 15, 0.30, 0.35))))) AS ?limit)\n    }\n  }\n  BIND(afn:sqrt((?limit1 * ?v1) * (?limit1 * ?v1) + (?limit2 * ?v2) * (?limit2 * ?v2)) / (?v1 + ?v2) AS ?sigmaRel)\n}\nORDER BY DESC(?kgValue)\nLIMIT 50') BLOCKED-bad-class
      [composition] a1 step 19 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nSELECT ?whole\n       (?itemMass * ?v1 * ?v2 AS ?kg)\n       ((?v1 * ?v2) * ?itemMass * ?limit / 1.7320508 AS ?sigmaAbs)\nWHERE {\n  ?whole a ?segClass .\n  ?segClass rdfs:subClassOf <https://www.purl.org/futuram#elvBEV> .\n  FILTER(STRENDS(STR(?whole), "_2020"))\n  ?whole futuram:hasCompositionStatement ?st1 .\n  ?st1 futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?mid .\n  ?mid a <https://www.purl.org/futuram#elvGeneralComponents> .\n  ?pr1 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v1 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?mid futuram:hasCompositionStatement ?st2 .\n  ?st2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?leaf .\n  ?leaf a/rdfs:subClassOf* <https://www.purl.org/futuram#5xxxAlAlloy> .\n  ?pr2 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v2 ; qudt:unit <http://qudt.org/vocab/unit/KiloGM-PER-KiloGM> ] .\n  ?whole futuram:itemMass [ qudt:numericValue ?itemMass ; qudt:unit <http://qudt.org/vocab/unit/KiloGM> ] .\n  {\n    SELECT ?pr2 (SUM(?w*?s) AS ?wsum) WHERE {\n      ?pr2 dqv:hasQualityMeasurement ?qm .\n      ?qm dqv:isMeasurementOf ?dim .\n      ?qm dqv:value ?s .\n      BIND(IF(?dim = <https://www.purl.org/futuram#IntegrityScore>, 0.5, IF(?dim = <https://www.purl.org/futuram#TimelinessScore>, 1.5, 1.0)) AS ?w)\n    } GROUP BY ?pr2\n  }\n  BIND(IF(?wsum < 7, 0.10, IF(?wsum < 9, 0.15, IF(?wsum < 10, 0.20, IF(?wsum < 14, 0.25, IF(?wsum < 15, 0.30, 0.35))))) AS ?limit)\n}\nORDER BY DESC(?kg)\nLIMIT 20')
