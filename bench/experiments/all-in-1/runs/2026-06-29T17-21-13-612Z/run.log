      [fq] a1 step 3 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl:     <http://www.w3.org/2002/07/owl#>\n\n# Step 1: discover direct components of the BEV segment C 2025 whole\nSELECT DISTINCT ?compClass ?compLabel ?compComment\nWHERE {\n  ?compClass rdfs:subClassOf+ futuram:Component .\n  ?scope futuram:partOf futuram:V0301030103_Y2025 ;\n         rdf:type ?compClass .\n  OPTIONAL { ?compClass rdfs:label ?compLabel }\n  OPTIONAL { ?compClass rdfs:comment ?compComment }\n}\nORDER BY ?compClass\nLIMIT 50')
      [fq] a1 step 4 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n\nSELECT DISTINCT ?compClass ?compLabel\nWHERE {\n  ?scope futuram:partOf futuram:V0301030103_Y2025 ;\n         rdf:type ?compClass .\n  ?compClass rdfs:subClassOf* futuram:Component .\n  OPTIONAL { ?compClass rdfs:label ?compLabel }\n}\nORDER BY ?compClass\nLIMIT 100')
      [fq] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>\n\n# Find scope nodes for motor, wiring(cables), electronics (embedded-electronics) inside the BEV segment C 2025 whole\nSELECT DISTINCT ?scope ?scopeType ?itemMass WHERE {\n  VALUES ?scopeType {\n    futuram:elvElectricMotor\n    futuram:elvElectricMotor_Y2025\n    futuram:elvEmbeddedElectronicsCables\n    futuram:elvEmbeddedElectronicsCables_Y2025\n    futuram:elvEmbeddedElectronics\n    futuram:elvEmbeddedElectronics_Y2025\n    futuram:elvPowerElectronics\n    futuram:elvPowerElectronics_Y2025\n  }\n  ?scope futuram:partOf futuram:V0301030103_Y2025 ;\n         rdf:type  ?scopeType ;\n         fq:itemMass ?itemMass .\n}\nORDER BY ?scopeType ?scope') BLOCKED-bad-class
      [fq] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>\n\n# Resolve copper element IRI within this endpoint\'s class hierarchy\nSELECT DISTINCT ?copperClass WHERE {\n  ?copperClass rdfs:subClassOf* futuram:Element .\n  ?copperClass rdfs:label ?label .\n  FILTER(LANG(?label) = "en")\n  FILTER(CONTAINS(LCASE(STR(?label)), "copper"))\n}')
      [fq] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>\n\n# Find classes whose label matches \'motor\', \'cable\'/\'wiring\', \'electronics\' - parent classes (no _Yxxxx suffix)\nSELECT DISTINCT ?cls ?label WHERE {\n  ?cls a owl:Class ;\n       rdfs:label ?label .\n  FILTER(LANG(?label) = "en")\n  FILTER(\n    CONTAINS(LCASE(STR(?label)), "electric motor") ||\n    CONTAINS(LCASE(STR(?label)), "cable") ||\n    CONTAINS(LCASE(STR(?label)), "wiring") ||\n    CONTAINS(LCASE(STR(?label)), "power electronics") ||\n    CONTAINS(LCASE(STR(?label)), "embedded electronics")\n  )\n}\nORDER BY ?label')
      [fq] a1 step 7 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n\n# Find the scope nodes for the three components (motor, wiring=cables, electronics)\nSELECT DISTINCT ?scope ?scopeType WHERE {\n  ?scope futuram:partOf futuram:V0301030103_Y2025 ;\n         rdf:type ?scopeType .\n  # Use the parent aggregate classes (each is one rollup node)\n  FILTER(?scopeType IN (futuram:elvElectricMotor,\n                        futuram:elvEmbeddedElectronicsCables,\n                        futuram:elvEmbeddedElectronics))\n}\nORDER BY ?scopeType') BLOCKED-bad-class
      [fq] a1 step 8 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>\n\n# Discover each user\'s category by matching against the LABEL of the scope node\'s component class\nSELECT ?scope ?scopeType ?typeLabel WHERE {\n  ?scope futuram:partOf futuram:V0301030103_Y2025 ;\n         rdf:type ?scopeType .\n  ?scopeType rdfs:label ?typeLabel .\n  FILTER(LANG(?typeLabel) = "en")\n  # Match the user\'s three named categories via label text only\n  FILTER(\n    CONTAINS(LCASE(STR(?typeLabel)), "electric motor") ||\n    CONTAINS(LCASE(STR(?typeLabel)), "cable") ||\n    CONTAINS(LCASE(STR(?typeLabel)), "embedded electronics")\n  )\n}\nORDER BY ?typeLabel')
