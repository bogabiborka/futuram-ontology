      [fq] a1 step 3 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nSELECT DISTINCT ?cls ?label ?comment WHERE {\n  ?cls a owl:Class .\n  OPTIONAL { ?cls rdfs:label ?label }\n  OPTIONAL { ?cls rdfs:comment ?comment }\n  FILTER(\n    CONTAINS(LCASE(STR(?label)), "embedded electronics") ||\n    CONTAINS(LCASE(STR(?comment)), "embedded electronics") ||\n    CONTAINS(LCASE(STR(?label)), "electronics") ||\n    CONTAINS(LCASE(STR(?comment)), "electronic")\n  )\n}\nLIMIT 80')
      [fq] a1 step 3 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nSELECT DISTINCT ?cls ?label ?comment WHERE {\n  ?cls a owl:Class .\n  OPTIONAL { ?cls rdfs:label ?label }\n  OPTIONAL { ?cls rdfs:comment ?comment }\n  FILTER(\n    CONTAINS(LCASE(STR(?label)), "battery electric") ||\n    CONTAINS(LCASE(STR(?comment)), "battery electric") ||\n    CONTAINS(LCASE(STR(?label)), "bev") ||\n    CONTAINS(LCASE(STR(?label)), "electric vehicle")\n  )\n}\nLIMIT 80')
      [fq] a1 step 4 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nSELECT DISTINCT ?cls ?label ?comment WHERE {\n  ?cls a owl:Class .\n  OPTIONAL { ?cls rdfs:label ?label }\n  OPTIONAL { ?cls rdfs:comment ?comment }\n  FILTER(\n    ( CONTAINS(LCASE(STR(?label)), "embedded electronics") ||\n      CONTAINS(LCASE(STR(?comment)), "embedded electronics") ) &&\n    ( CONTAINS(LCASE(STR(?label)), "bev") || CONTAINS(LCASE(STR(?comment)), "battery-electric") || CONTAINS(LCASE(STR(?label)), "standard") )\n  )\n}\nLIMIT 80')
      [fq] a1 step 4 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nSELECT DISTINCT ?cls ?label ?comment WHERE {\n  ?cls a owl:Class .\n  OPTIONAL { ?cls rdfs:label ?label }\n  OPTIONAL { ?cls rdfs:comment ?comment }\n  FILTER(\n    ( CONTAINS(LCASE(STR(?label)), "elvBEV") || CONTAINS(LCASE(STR(?label)), "BEV_elvEmbedded") )\n  )\n}\nLIMIT 60')
      [fq] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nSELECT DISTINCT ?cls ?label ?comment WHERE {\n  ?cls a owl:Class .\n  OPTIONAL { ?cls rdfs:label ?label }\n  OPTIONAL { ?cls rdfs:comment ?comment }\n  FILTER( CONTAINS(LCASE(STR(?label)), "elv"))\n}\nLIMIT 200')
      [fq] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nSELECT DISTINCT ?cls ?label ?comment WHERE {\n  ?cls a owl:Class .\n  OPTIONAL { ?cls rdfs:label ?label }\n  OPTIONAL { ?cls rdfs:comment ?comment }\n  ?cls fq:sliceOf ?base .\n  ?base rdfs:label ?baseLabel .\n  FILTER( CONTAINS(LCASE(STR(?baseLabel)), "embedded electronics") )\n}\nLIMIT 100')
      [fq] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nSELECT ?cls ?label ?comment WHERE {\n  ?cls a owl:Class ;\n       rdfs:label ?label ;\n       fq:sliceAxis ?axis .\n  OPTIONAL { ?cls rdfs:comment ?comment }\n  FILTER( CONTAINS(LCASE(STR(?label)), "embedded electronics") )\n}\nLIMIT 60')
      [fq] a1 step 7 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\n\n# What is the aggregate class that these slice classes roll up to?\nSELECT ?agg ?labelAgg ?slc ?labelSlc WHERE {\n  ?slc a owl:Class ; rdfs:subClassOf ?agg ; rdfs:label ?labelSlc .\n  ?agg rdfs:label ?labelAgg .\n  FILTER(STRSTARTS(STR(?slc), "https://www.purl.org/futuram#elvBEV_"))\n  FILTER(CONTAINS(LCASE(?labelSlc), "embedded electronics"))\n  FILTER(CONTAINS(LCASE(?labelSlc), "2025"))\n}\nLIMIT 50')
      [fq] a1 step 8 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX mw: <https://purl.org/metalwheel#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\n\n# For embedded-electronics scope nodes inside the standard BEV Y2025 whole,\n# list every critical raw material constituent with kg, ± kg, and the metal-wheel\n# recovery process / base metal per recovery route.\nSELECT DISTINCT ?nodeLabel ?constituent ?baseMetal ?route ?eff\n       (?frac * ?itemMass AS ?kg)\n       (?relUnc * ?frac * ?itemMass AS ?uncKg)\nWHERE {\n  ?node futuram:partOf futuram:V0301030000_Y2025 ;\n        rdf:type ?scopedType ;\n        fq:itemMass ?itemMass ;\n        fq:contains [ fq:constituent ?constituent ;\n                      fq:amount ?frac ;\n                      fq:relativeUncertainty ?relUnc ] .\n  FILTER( CONTAINS( LCASE(STR(?scopedType)), "elvembeddedelectronics" ) )\n  # Criticality flag on the element via Chebi bridge\n  ?constituent rdfs:subClassOf ?chebi .\n  FILTER( CONTAINS(STR(?chebi), "CHEBI") )\n  ?chebi crit:remark ?flag .\n  # Metal-Wheel recovery routes for this CRM (targeted + accompanying only)\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasRecoveryProcess ?route ;\n      mw:hasExpectedRecoveryEffectiveness ?eff .\n  FILTER( ?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement) )\n  BIND( STR(?scopedType) AS ?nodeLabel )\n}\nORDER BY ?constituent ?baseMetal\n') BLOCKED-bad-class
      [fq] a1 step 9 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX mw: <https://purl.org/metalwheel#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\n\nSELECT DISTINCT ?scopedLabel ?constituent ?baseMetal ?route ?eff\n       (?frac * ?itemMass AS ?kg)\n       (?relUnc * ?frac * ?itemMass AS ?uncKg)\nWHERE {\n  ?node futuram:partOf futuram:V0301030000_Y2025 ;\n        rdf:type ?scopedType ;\n        fq:itemMass ?itemMass ;\n        fq:contains [ fq:constituent ?constituent ;\n                      fq:amount ?frac ;\n                      fq:relativeUncertainty ?relUnc ] .\n  ?scopedType a owl:Class .\n  OPTIONAL { ?scopedType rdfs:label ?scopedLabel }\n  FILTER( CONTAINS(LCASE(STR(?scopedLabel)), "embedded electronics") )\n  ?constituent rdfs:subClassOf ?chebi .\n  FILTER( CONTAINS(STR(?chebi), "CHEBI") )\n  ?chebi crit:remark ?flag .\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasRecoveryProcess ?route ;\n      mw:hasExpectedRecoveryEffectiveness ?eff .\n  FILTER( ?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement) )\n}\nORDER BY ?constituent ?baseMetal ?scopedLabel\n')
      [fq] a1 step 10 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX mw: <https://purl.org/metalwheel#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX afn: <http://jena.apache.org/ARQ/function#>\n\n# Restrict to the AGGREGATE embedded-electronics scope node for the standard BEV Y2025.\n# Aggregate per (constituent, baseMetal, route).\nSELECT ?constituent ?baseMetal ?route ?eff\n       (SUM(?kg) AS ?totKg)\n       (afn:sqrt(SUM(?uncKg*?uncKg)) AS ?totUncKg)\nWHERE {\n  ?node futuram:partOf futuram:V0301030000_Y2025 ;\n        rdf:type ?aggType ;\n        fq:itemMass ?itemMass ;\n        fq:contains [ fq:constituent ?constituent ;\n                      fq:amount ?frac ;\n                      fq:relativeUncertainty ?relUnc ] .\n  ?aggType a owl:Class ; rdfs:label ?aggLabel .\n  FILTER( ?aggLabel = "embedded electronics — 2025 production year" )\n  ?constituent rdfs:subClassOf ?chebi .\n  FILTER( CONTAINS(STR(?chebi), "CHEBI") )\n  ?chebi crit:remark ?flag .\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasRecoveryProcess ?route ;\n      mw:hasExpectedRecoveryEffectiveness ?eff .\n  FILTER( ?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement) )\n  BIND( (?frac * ?itemMass) AS ?kg )\n  BIND( (?relUnc * ?frac * ?itemMass) AS ?uncKg )\n}\nGROUP BY ?constituent ?baseMetal ?route ?eff\nORDER BY ?constituent ?baseMetal\n')
      [fq] a1 step 11 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX fq: <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX mw: <https://purl.org/metalwheel#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX afn: <http://jena.apache.org/ARQ/function#>\n\nSELECT ?constituent ?baseMetal ?route ?eff ?aggLabel\n       (SUM(?kg) AS ?totKg)\n       (afn:sqrt(SUM(?uncKg*?uncKg)) AS ?totUncKg)\nWHERE {\n  ?node futuram:partOf futuram:V0301030000_Y2025 ;\n        rdf:type ?aggType ;\n        fq:itemMass ?itemMass ;\n        fq:contains [ fq:constituent ?constituent ;\n                      fq:amount ?frac ;\n                      fq:relativeUncertainty ?relUnc ] .\n  ?aggType a owl:Class ; rdfs:label ?aggLabel .\n  FILTER( CONTAINS(?aggLabel, "embedded electronics") && CONTAINS(?aggLabel, "2025") )\n  ?constituent rdfs:subClassOf ?chebi .\n  FILTER( CONTAINS(STR(?chebi), "CHEBI") )\n  ?chebi crit:remark ?flag .\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasRecoveryProcess ?route ;\n      mw:hasExpectedRecoveryEffectiveness ?eff .\n  FILTER( ?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement) )\n  BIND( (?frac * ?itemMass) AS ?kg )\n  BIND( (?relUnc * ?frac * ?itemMass) AS ?uncKg )\n}\nGROUP BY ?constituent ?baseMetal ?route ?eff ?aggLabel\nORDER BY ?constituent ?baseMetal\n')
