      [fq] a1 step 2 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/01/rdf-schema#>\nSELECT ?node ?type ?label WHERE {\n  ?node futuram:partOf <https://www.purl.org/futuram#V0301030000_Y2025> ;\n        rdf:type ?type .\n  ?type rdfs:label ?label .\n  FILTER(CONTAINS(LCASE(?label), "electronic"))\n} LIMIT 50')
      [fq] a1 step 3 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/01/rdf-schema#>\nSELECT ?node ?type ?typeLabel WHERE {\n  ?node futuram:partOf <https://www.purl.org/futuram#V0301030000_Y2025> ;\n        rdf:type ?type .\n  OPTIONAL { ?type rdfs:label ?typeLabel . }\n} ORDER BY ?typeLabel')
      [fq] a1 step 4 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nSELECT ?key ?frac ?unc ?m WHERE {\n  ?node futuram:partOf <https://www.purl.org/futuram#V0301030000_Y2025> ;\n        rdf:type <https://www.purl.org/futuram#elvEmbeddedElectronics> ;\n        fq:itemMass ?m ;\n        fq:contains [ fq:constituent ?key ; fq:amount ?frac ; fq:relativeUncertainty ?unc ] .\n} ORDER BY DESC(?frac)')
      [fq] a1 step 5 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/01/rdf-schema#>\nPREFIX crit:    <http://purl.org/futuram/criticality#>\nPREFIX mw:      <https://purl.org/metalwheel#>\nSELECT DISTINCT ?key (?frac * ?m AS ?kg) (?ru * ?frac * ?m AS ?unc) ?baseMetal ?route ?eff ?chebi WHERE {\n  ?node futuram:partOf <https://www.purl.org/futuram#V0301030000_Y2025> ;\n        rdf:type <https://www.purl.org/futuram#elvEmbeddedElectronics> ;\n        fq:itemMass ?m ;\n        fq:contains [ fq:constituent ?key ; fq:amount ?frac ; fq:relativeUncertainty ?ru ] .\n  ?key rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi), "CHEBI"))\n  ?chebi crit:remark ?flag .\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ;\n      mw:hasRecoveryProcess ?route ;\n      mw:hasExpectedRecoveryEffectiveness ?eff .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n} ORDER BY ?key ?baseMetal')
      [fq] a1 step 6 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX fq:      <https://www.purl.org/futuram/query#>\nPREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX rdfs:    <http://www.w3.org/2000/01/01/rdf-schema#>\nSELECT ?p ?o WHERE {\n  <https://www.purl.org/futuram#Copper> ?p ?o .\n} LIMIT 50')
      [fq] a1 step 7 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX crit:    <http://purl.org/futuram/criticality#>\nPREFIX mw:      <https://purl.org/metalwheel#>\nSELECT ?p ?o WHERE {\n  <http://purl.obolibrary.org/obo/CHEBI_28694> ?p ?o .\n} LIMIT 100')
      [fq] a1 step 8 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/query/sparql"}, "sparql_query": 'PREFIX mw:      <https://purl.org/metalwheel#>\nSELECT DISTINCT ?eff WHERE {\n  ?s a ?eff .\n  FILTER(STRSTARTS(STR(?eff), "https://purl.org/metalwheel#"))\n} LIMIT 30')
