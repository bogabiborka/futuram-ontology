      [composition] a3 step 19 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX afn: <http://jena.apache.org/ARQ/function#>\nSELECT ?whole ?v ?u ?el ?elLabel (?v*?v AS ?v2) WHERE {\n  ?whole ?p ?o .\n  FILTER(CONTAINS(STR(?whole), "elvTractionMotorPM__V0301030103_2025"))\n  ?whole futuram:hasCompositionStatement ?stmt .\n  ?stmt futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?mid1 .\n  ?pr1 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?v ; qudt:unit ?u ] .\n  ?mid1 a ?el .\n  ?el rdfs:subClassOf* <http://purl.obolibrary.org/obo/CHEBI_33321> .\n  OPTIONAL { ?el rdfs:label ?elLabel }\n}\nLIMIT 10')
