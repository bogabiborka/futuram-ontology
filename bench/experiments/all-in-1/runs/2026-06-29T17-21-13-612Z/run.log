      [composition] a1 step 16 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX mw: <https://www.purl.org/metalwheel#>\nPREFIX afn: <http://jena.apache.org/ARQ/function#>\nSELECT ?subComponent ?element ?v_kg ?v_kg_unc ?baseMetal ?route WHERE {\n  {\n    SELECT ?whole ?subComponent ?element (SUM(?frac1*?frac2)?total_frac AS ?frac_sum) WHERE {\n      VALUES ?whole {\n        <https://www.purl.org/futuram/example#V0301030105_2025>\n      }\n      ?whole futuram:hasCompositionStatement ?stmt1 .\n      ?stmt1 futuram:hasPartRelation ?pr1 .\n      ?pr1 futuram:refersTo ?subComponent .\n      ?pr1 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?frac1 ; qudt:unit unit:KiloGM-PER-KiloGM ] .\n      ?subComponent a ?embType .\n      FILTER(?embType IN (futuram:elvEmbeddedElectronicsCables,\n                          futuram:elvEmbeddedElectronicsControllers,\n                          futuram:elvEmbeddedElectronicsActuators,\n                          futuram:elvEmbeddedElectronicsHeadlights))\n      ?subComponent futuram:hasCompositionStatement ?stmt2 .\n      ?stmt2 futuram:hasPartRelation ?pr2 .\n      ?pr2 futuram:refersTo ?element .\n      ?pr2 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?frac2 ; qudt:unit unit:KiloGM-PER-KiloGM ] .\n      ?element a ?elType . FILTER(?elType = futuram:Element)\n    } GROUP BY ?subComponent ?element\n  }\n  BIND(?frac_sum * 2601.597e0 AS ?v_kg)\n  ?element rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi),"CHEBI"))\n  ?chebi crit:remark ?flag .\n  # Uncertainty: average per hop via DQ rectangular distributed weights\n  {\n    SELECT ?whole ?subComponent ?element (SUM(?sigma1_sq)+SUM(?sigma2_sq) AS ?sigma_sum_sq) WHERE {\n      ?whole futuram:hasCompositionStatement ?stmt1 .\n      ?stmt1 futuram:hasPartRelation ?pr1 .\n      ?pr1 futuram:refersTo ?subComponent .\n      ?pr1 dqv:hasQualityMeasurement ?qm1 .\n      ?qm1 dqv:isMeasurementOf ?met1 ; dqv:value ?val1 .\n      ?subComponent futuram:hasCompositionStatement ?stmt2 .\n      ?stmt2 futuram:hasPartRelation ?pr2 .\n      ?pr2 futuram:refersTo ?element .\n      ?pr2 dqv:hasQualityMeasurement ?qm2 .\n      ?qm2 dqv:isMeasurementOf ?met2 ; dqv:value ?val2 .\n      BIND(0.25e0 AS ?sigma1_sq)\n    } GROUP BY ?whole ?subComponent ?element\n  }\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ; mw:hasRecoveryProcess ?route ; mw:hasExpectedRecoveryEffectiveness ?eff .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n}') BLOCKED-bad-class
      [composition] a1 step 17 -> execute_sparql_query({"endpoint_url": "http://bench-fuseki:3030/composition/sparql"}, "sparql_query": 'PREFIX futuram: <https://www.purl.org/futuram#>\nPREFIX qudt: <http://qudt.org/schema/qudt/>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX dqv: <http://www.w3.org/ns/dqv#>\nPREFIX crit: <http://purl.org/futuram/criticality#>\nPREFIX mw: <https://www.purl.org/metalwheel#>\nPREFIX afn: <http://jena.apache.org/ARQ/function#>\nSELECT ?subComponent ?element ?v_kg ?baseMetal ?route ?criticality WHERE {\n  # Hop 1: whole (BEV) -> embedded electronics component\n  <https://www.purl.org/futuram/example#V0301030105_2025> futuram:hasCompositionStatement ?stmt1 .\n  ?stmt1 futuram:hasPartRelation ?pr1 .\n  ?pr1 futuram:refersTo ?subComponent .\n  ?pr1 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?frac1 ; qudt:unit unit:KiloGM-PER-KiloGM ] .\n  # scope to embedded electronics subcomponents\n  ?subComponent rdfs:subClassOf* futuram:elvEmbeddedElectronics .\n  # Hop 2: subComponent -> element\n  ?subComponent futuram:hasCompositionStatement ?stmt2 .\n  ?stmt2 futuram:hasPartRelation ?pr2 .\n  ?pr2 futuram:refersTo ?element .\n  ?pr2 futuram:hasQuantity/futuram:hasBestValue [ qudt:numericValue ?frac2 ; qudt:unit unit:KiloGM-PER-KiloGM ] .\n  ?element a futuram:Element .\n  BIND(?frac1 * ?frac2 * 2601.597e0 AS ?v_kg)\n  # Criticality filter\n  ?element rdfs:subClassOf ?chebi . FILTER(CONTAINS(STR(?chebi),"CHEBI"))\n  ?chebi crit:remark ?flag .\n  ?flag crit:importance ?criticality .\n  # Metal-wheel recovery routes\n  ?chebi mw:hasRecoveryInformation ?ri .\n  ?ri mw:hasBaseMetal ?baseMetal ; mw:hasRecoveryProcess ?route ; mw:hasExpectedRecoveryEffectiveness ?eff .\n  FILTER(?eff IN (mw:TargetedElement, mw:MainlyRecoveredElement))\n} ORDER BY ?element ?baseMetal')
