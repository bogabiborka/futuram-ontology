        [ rdfs:label "has part relation"@en ;
            void:classPartition [ void:class futuram:PartRelation ] ;
            void:property futuram:hasPartRelation ;
            rdfs:comment "Links a CompositionStatement (about a whole, a ceon:Composition) to one of its qualified PartRelations — one per constituent child. The grouping predicate that lets a single statement carry the whole's full composition (N parts) as N qualified relations. The futuram analogue of ceon:hasConstituent, but ranging over a recursive qualified relation rather than CEON's non-recursive Constituent leaf." ],
