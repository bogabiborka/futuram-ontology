[] void:class futuram:elvBEV ;
    void:propertyPartition [ void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property rdfs:label ],
        [ rdfs:label "futuram-hasCompositionStatement" ;
            void:classPartition [ void:class ceonst:ProductCompositionStatement ],
                [ void:class <http://w3id.org/CEON/ontology/product/Composition> ],
                [ void:class futuram:CompositionStatement ] ;
            void:property futuram:hasCompositionStatement ;
            rdfs:comment "Links the whole (a concrete product, component or material individual) to its per-whole CompositionStatement, which groups all of the whole's constituents as qualified part-relations. Sub-property of ceon:hasComposition (CEON's whole->composition link); revives the legacy futuram:hasCompositionStatement direction. Its inverse is ceon:compositionOf (composition->whole)." ],
        [ rdfs:label "reference year"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:int ] ;
            void:property futuram:referenceYear ;
            rdfs:comment "The reference / production year qualifying a product (or component) CLASS, e.g. a 2026 small-car class. The year is a property of the class an instance is typed into, not of the instance or the statement itself." ],
        [ rdfs:label "item mass"@en ;
            void:classPartition [ void:class qudt:QuantityValue ] ;
            void:property futuram:itemMass ;
            rdfs:comment "The absolute mass of ONE item of a Product/Component, as a QUDT quantity value in kilograms. The REFERENCE ANCHOR that turns the otherwise purely fractional (kg/kg) composition into absolute amounts: the absolute mass of a constituent in a whole = itemMass(whole) x its kg/kg composition fraction. Composition math itself stays kg/kg and is unaffected; itemMass plays no part in mass conservation. Carried per INSTANCE as a measured fact; the CLASS-level value is DERIVED, resolving exactly like a composition statement — a measured instance value wins, otherwise the class's futuram:hasAggregationStrategy derives it via the strategy's futuram:massAggregation facet (mean over slices/subclasses, or sum over composition parts). Restricted to Product/Component (countable items); Material and Element have no item mass because matter is bulk, measured per kilogram, never counted." ] ;
    rdfs:comment "A concrete constituent class with individuals. The property partitions are the predicates an instance of this class carries (?inst a <thisClass> ; <pred> …); a class-level number is an AGGREGATE over those instances." .

