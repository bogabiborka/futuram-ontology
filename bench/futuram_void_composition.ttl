            void:property prov:wasAttributedTo ;
            rdfs:comment "Attributes the composition statement to the prov:Agent (person or organisation) responsible for asserting it — i.e. who told you this. Standard PROV-O term, declared here for documentation." ],
        [ rdfs:label "has validity period"@en ;
            void:classPartition [ void:class time:Interval ] ;
            void:property futuram:hasValidityPeriod ;
            rdfs:comment "The real-world time interval (valid-time) over which the composition asserted by this statement holds. Ranges over a W3C Time time:Interval bounded by time:hasBeginning / time:hasEnd. Distinct from futuram:referenceYear (a class annotation) and from CEON's availableStartDate/availableEndDate (data availability / transaction-time)." ] .

[] rdfs:label "futuram-Aggregation Strategy"@en ;
    void:class futuram:AggregationStrategy ;
    void:propertyPartition [ void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property rdfs:comment ],
        [ rdfs:label "DQV aggregation"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property futuram:dqvAggregation ;
            rdfs:comment "How the children's DQV quality measurements (per-dimension scores) aggregate to class level. DECLARED rule; the resolver does not yet materialise class-level DQV measurements." ],
        [ rdfs:label "presented by"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property futuram:presentedBy ;
            rdfs:comment "ORCID (or other identifier) of the person who presented / authored the term." ],
        [ void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property rdfs:label ],
        [ rdfs:label "value aggregation"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property futuram:valueAggregation ;
            rdfs:comment "How the central (best) composition values of the children aggregate. Controlled token; the rdfs:comment on each strategy individual states the exact rule." ],
        [ rdfs:label "time scope aggregation"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property futuram:timeScopeAggregation ;
            rdfs:comment "How the children's reference years/periods determine the aggregate's time scope (same-slice-only, span-of-slices, or time-independent)." ],
        [ rdfs:label "provenance aggregation"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property futuram:provenanceAggregation ;
            rdfs:comment "How PROV lineage aggregates: which sources/agents/activities the derived ClassCompositionStatement records." ],
        [ rdfs:label "remainder aggregation"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property futuram:remainderAggregation ;
            rdfs:comment "How the unattributed remainder (coverage / unknown* placeholders) rolls up to class level." ],
        [ rdfs:label "uncertainty aggregation"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property futuram:uncertaintyAggregation ;
            rdfs:comment "How the uncertainty (interval bounds / Monte-Carlo distributions) of the children aggregates." ],
        [ rdfs:label "mass aggregation"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property futuram:massAggregation ;
            rdfs:comment "How the children's item masses (futuram:itemMass, the absolute kg of a whole) combine to the class-level item mass. Controlled token; the rdfs:comment on each strategy individual states the exact rule. Two directions occur and the token selects between them: 'sum-of-part-masses' for the parts->whole composition direction (a whole's mass is the sum of its constituent parts' masses), and 'equal-subclass-mean' / 'equal-year-slice-mean' / 'equal-drivetrain-slice-mean' for the slice/drivetrain/subclass->base direction (a base/bucket's mass is the mean of its slices' masses). itemMass resolves like a composition statement: a measured instance value wins; an absent value is derived by this facet. Mass aggregation is mean-or-sum, decided here on the strategy IRI, never hard-coded in code." ] ;
    rdfs:comment "A way a class-level composition is DERIVED instead of measured. Attached to the CLASS (punned node) via futuram:hasAggregationStrategy — aggregation is class-level in this model (futuram:ClassCompositionStatement already has a class as its whole). Each named individual MUST declare all seven facet properties (SHACL S3): futuram:valueAggregation, uncertaintyAggregation, dqvAggregation, remainderAggregation, provenanceAggregation, timeScopeAggregation, massAggregation." .

