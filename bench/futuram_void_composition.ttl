                [ void:class futuram:PCBelectronics ],
                [ void:class futuram:mildSteel ],
                [ void:class futuram:V0301030202 ],
                [ void:class futuram:6xxxAlAlloy ],
                [ void:class futuram:pureCu_in_elvElectricMotor ],
