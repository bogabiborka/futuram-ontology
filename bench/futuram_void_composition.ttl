[] rdfs:label "futuram-Uniform Distribution"@en ;
    void:class futuram:UniformDistribution ;
    void:propertyPartition [ rdfs:label "lower bound"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:double ] ;
            void:property futuram:lowerBound ;
            rdfs:comment "The lower bound (support minimum) of a bounded distribution — the lower vertex of a triangular distribution or the lower limit of a uniform distribution. In the same fraction unit as the quantity's best value." ],
        [ rdfs:label "upper bound"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:double ] ;
            void:property futuram:upperBound ;
            rdfs:comment "The upper bound (support maximum) of a bounded distribution — the upper vertex of a triangular distribution or the upper limit of a uniform distribution. In the same fraction unit as the quantity's best value." ] ;
    rdfs:comment "Continuous uniform distribution: every value in [lowerBound, upperBound] is equally likely (the best value is the midpoint, informational). Requires futuram:lowerBound and futuram:upperBound. Subclass of Apollo APOLLO_SV_00000257 (continuous uniform distribution)." .

