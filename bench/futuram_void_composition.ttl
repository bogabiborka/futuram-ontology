            void:property rdf:type ;
            rdfs:comment "instance -> its constituent class (the edge that connects a whole/part individual to the class a user names)" ],
        [ rdfs:label "has aggregation strategy"@en ;
            void:classPartition [ void:class futuram:AggregationStrategy ],
                [ void:class owl:NamedIndividual ] ;
            void:property futuram:hasAggregationStrategy ;
            rdfs:comment "Attaches an AggregationStrategy to the CLASS, not the instance (punning — fine in RDF/SHACL). A class with a declared strategy is a valid composition source even when statement-less: its composition comes via aggregation. Distinguishes 'intentionally statement-less' from 'accidentally incomplete data'." ],
        [ rdfs:label "futuram-hasCompositionStatement" ;
            void:classPartition [ void:class futuram:CompositionStatement ],
                [ void:class <http://w3id.org/CEON/ontology/product/Composition> ],
                [ void:class ceonst:ProductCompositionStatement ] ;
            void:property futuram:hasCompositionStatement ;
            rdfs:comment "Links the whole (a concrete product, component or material individual) to its per-whole CompositionStatement, which groups all of the whole's constituents as qualified part-relations. Sub-property of ceon:hasComposition (CEON's whole->composition link); revives the legacy futuram:hasCompositionStatement direction. Its inverse is ceon:compositionOf (composition->whole)." ],
        [ void:classPartition [ void:class futuram:TimeBasedClassFamily ],
                [ void:class owl:Class ] ;
            void:property rdfs:subClassOf ],
        [ rdfs:label "reference year"@en ;
            void-ext:datatypePartition [ void-ext:datatype xsd:int ] ;
            void:property futuram:referenceYear ;
            rdfs:comment "The reference / production year qualifying a product (or component) CLASS, e.g. a 2026 small-car class. The year is a property of the class an instance is typed into, not of the instance or the statement itself." ],
        [ void-ext:datatypePartition [ void-ext:datatype xsd:string ] ;
            void:property rdfs:label ] ;
    rdfs:comment "Constituent classes (the domain vocabulary): every Product/Component/Material/Element class and its per-year slice. One summarised partition for ALL such classes. IMPORTANT: a statement's whole (subject of futuram:hasCompositionStatement) and its parts (object of futuram:refersTo on each futuram:PartRelation) are INSTANCES (individuals), NOT these classes. A class name is therefore NOT itself a whole or part — do not filter them by a class-name string; reach the class via the instance's rdf:type. Resolve a plain-language term to a class IRI via rdfs:label on the class. Each instance is linked to its class by rdf:type (?instance a ?class). Classes chain to coarser, user-named base classes via rdfs:subClassOf (a per-year slice rdfs:subClassOf its base). So to go from a class a user NAMES to its statements: find the instances of it or its subclasses with  ?inst rdf:type/rdfs:subClassOf* <thatClass> , then traverse  ?inst futuram:hasCompositionStatement ?stmt . ?stmt futuram:hasPartRelation ?pr . ?pr futuram:refersTo ?part ; futuram:hasQuantity ?q .  A single class-level number is an AGGREGATE over those instances (this endpoint does not store it; you must compute it)." .

