                [ void:class futuram:elvPowerElectronics ],
                [ void:class futuram:CuAndCuAlloys ],
                [ void:class futuram:PCBelectronics_in_elvEmbeddedElectronicsHeadlights ],
                [ void:class futuram:alloySteel ],
                [ void:class futuram:pureCu_in_elvEmbeddedElectronicsCables ],
                [ void:class futuram:magnetAlloysNdFeB ],
                [ void:class futuram:wroughtAlAlloys ],
                [ void:class futuram:elvElectricMotor ],
                [ void:class futuram:Product ],
