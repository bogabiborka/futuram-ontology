                [ void:class futuram:PlaceholderMaterials ],
                [ void:class futuram:elvEmbeddedElectronicsCables ] ;
            void:property <http://w3id.org/CEON/ontology/product/compositionOf> ],
        [ rdfs:label "has part relation"@en ;
            void:classPartition [ void:class futuram:PartRelation ] ;
            void:property futuram:hasPartRelation ;
            rdfs:comment "Links a CompositionStatement (about a whole, a ceon:Composition) to one of its qualified PartRelations — one per constituent child. The grouping predicate that lets a single statement carry the whole's full composition (N parts) as N qualified relations. The futuram analogue of ceon:hasConstituent, but ranging over a recursive qualified relation rather than CEON's non-recursive Constituent leaf." ],
        [ rdfs:label "has validity period"@en ;
            void:classPartition [ void:class time:Interval ] ;
            void:property futuram:hasValidityPeriod ;
            rdfs:comment "The real-world time interval (valid-time) over which the composition asserted by this statement holds. Ranges over a W3C Time time:Interval bounded by time:hasBeginning / time:hasEnd. Distinct from futuram:referenceYear (a class annotation) and from CEON's availableStartDate/availableEndDate (data availability / transaction-time)." ],
        [ rdfs:label "had primary source"@en ;
            void:classPartition [ void:class futuram:Source ],
                [ void:class prov:Entity ] ;
            void:property prov:hadPrimarySource ;
            rdfs:comment "Links the composition statement to the PRIMARY source (a futuram:Source / prov:Entity) the stated value was taken from. Revives the legacy provenance predicate (prov:hadPrimarySource, a specialisation of prov:wasDerivedFrom for the originating source). Standard PROV-O term." ] ;
    rdfs:comment "A FutuRaM specialisation of the CEON Product Composition Statement AND a ceon:Composition: the per-whole node that GROUPS the whole's constituents. The whole links to it via ceon:hasComposition; it links back via ceon:compositionOf; and it carries one futuram:PartRelation per constituent (futuram:hasPartRelation), each PartRelation holding that part's measured quantity and per-edge metadata. Being a ceon:Statement it is already a prov:Entity, describable with PROV-O. (Reshaped from the former per-(whole,part) statement: it is now per-WHOLE, grouping N qualified part-relations.)" .

