# 5xxx-series aluminium alloy in each BEV passenger-body segment, 2020.
# Material-level query (no element traversal): ?mat rdf:type futuram:5xxxAlAlloy.
# Uses compositionOf to reach the composition statement structurally.
# uncertainty = RSS of per-leaf relUnc * kg contributions (FuturamDQS).
PREFIX futuram: <https://www.purl.org/futuram#>
PREFIX ex:      <https://www.purl.org/futuram/example#>
PREFIX ceonp:   <http://w3id.org/CEON/ontology/product/>
PREFIX qudt:    <http://qudt.org/schema/qudt/>
PREFIX dqv:     <http://www.w3.org/ns/dqv#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>
PREFIX afn:     <http://jena.apache.org/ARQ/function#>
SELECT ?v (SUM(?kg) AS ?total) (afn:sqrt(SUM(?sig*?sig)) AS ?unc) WHERE {
  SELECT ?v (?mass * ?f1 * ?f2 AS ?kg) (?ru * ?mass * ?f1 * ?f2 AS ?sig) WHERE {
    ?v rdf:type futuram:elvBEV ;
       futuram:referenceYear "2020"^^xsd:int ;
       futuram:itemMass/qudt:numericValue ?mass .
    ?comp_stmt ceonp:compositionOf ?v ;
               futuram:hasPartRelation ?pr1 .
    ?pr1 futuram:refersTo ?comp ;
         futuram:hasQuantity/futuram:hasBestValue/qudt:numericValue ?f1 .
    ?comp futuram:hasCompositionStatement/futuram:hasPartRelation ?pr2 .
    ?pr2 futuram:refersTo ?mat ;
         futuram:hasQuantity/futuram:hasBestValue/qudt:numericValue ?f2 .
    ?mat rdf:type futuram:5xxxAlAlloy .
    # FuturamDQS: weighted sum of leaf DQV scores -> limit band -> relUnc
    { SELECT ?pr2 (
        IF(?wsum <  7.0, 0.1 ,
        IF(?wsum <  9.0, 0.15,
        IF(?wsum < 10.0, 0.2 ,
        IF(?wsum < 14.0, 0.25,
        IF(?wsum < 15.0, 0.3 , 0.35))))) / 1.7320508 AS ?ru)
      WHERE {
        { SELECT ?pr2
            (SUM(IF(?dim = dqv:Accuracy,    ?v*1.0,
                 IF(?dim = dqv:Completeness, ?v*1.0,
                 IF(?dim = dqv:Consistency,  ?v*1.0,
                 IF(?dim = dqv:Integrity,    ?v*0.5,
                 IF(?dim = dqv:Timeliness,   ?v*1.5,
                 IF(?dim = dqv:Validity,     ?v*1.0, 0))))))) AS ?wsum)
          WHERE {
            ?pr2 dqv:hasQualityMeasurement ?meas .
            ?meas dqv:isMeasurementOf/dqv:inDimension ?dim ; dqv:value ?v .
          } GROUP BY ?pr2
        }
      }
    }
  }
} GROUP BY ?v ORDER BY DESC(?total)
