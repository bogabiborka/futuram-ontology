@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix futuram: <https://www.purl.org/futuram#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

#################################################################
#
#    rdfs:label shape for the futuram-hierarchy classes.
#
#    Every owl:Class in the hierarchy MUST carry at least one
#    non-empty rdfs:label so the LLM (and any human-facing query
#    layer) has a human-readable handle for the term — the opaque
#    IRI local name alone is not enough to reason or surface a name.
#
#    Severity is sh:Violation: a class with no label is a hard
#    error, not a diagnostic warning.
#
#################################################################

futuram:HierarchyClassLabelShape a sh:NodeShape ;
    rdfs:label "Every hierarchy class carries an rdfs:label"@en ;
    sh:targetClass owl:Class ;
    sh:severity sh:Violation ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:minLength 1 ;
        sh:message "Every owl:Class MUST carry at least one non-empty rdfs:label (plain or language-tagged) so the LLM can work with it (the IRI local name alone is not a label)." ;
    ] .
