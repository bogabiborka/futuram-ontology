## Fuseki assembler config — two datasets over the persistent TDB2 stores.
##
##   /composition  -> the baseline composition futuram: dataset
##   /query        -> the query-optimized fq: dataset
##
## Each TDB2 store is loaded from the MOUNTED TTL at container startup (see
## fuseki/entrypoint.sh) and lives on a persistent volume.
##
## Both datasets expose READ + WRITE over HTTP:
##   query  (SPARQL query)            GET/POST  <ds>/sparql
##   update (SPARQL Update)           POST      <ds>/update
##   gsp-rw (Graph Store Protocol)    GET/PUT/POST/DELETE  <ds>/data  and <ds> (direct)
## Writes persist to the TDB2 volume immediately (no restart needed); the
## mount + restart path is for bulk/initial loads.

@prefix :        <#> .
@prefix fuseki:  <http://jena.apache.org/fuseki#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ja:      <http://jena.hpl.hp.com/2005/11/Assembler#> .
@prefix tdb2:    <http://jena.apache.org/2016/tdb#> .

[] rdf:type fuseki:Server ;
   fuseki:services ( :compositionService :queryService ) .

## --- /composition : internal futuram: model (read + write) ------------------
:compositionService a fuseki:Service ;
    fuseki:name "composition" ;
    fuseki:endpoint [ fuseki:operation fuseki:query ] ;
    fuseki:endpoint [ fuseki:operation fuseki:query  ; fuseki:name "sparql" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:update ; fuseki:name "update" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:gsp-rw ; fuseki:name "data" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:gsp-rw ] ;
    fuseki:dataset :compositionDataset .

:compositionDataset a tdb2:DatasetTDB2 ;
    tdb2:location "/fuseki-base/databases/composition" .

## --- /query : served fq: graph (read + write) -------------------------------
:queryService a fuseki:Service ;
    fuseki:name "query" ;
    fuseki:endpoint [ fuseki:operation fuseki:query ] ;
    fuseki:endpoint [ fuseki:operation fuseki:query  ; fuseki:name "sparql" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:update ; fuseki:name "update" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:gsp-rw ; fuseki:name "data" ] ;
    fuseki:endpoint [ fuseki:operation fuseki:gsp-rw ] ;
    fuseki:dataset :queryDataset .

:queryDataset a tdb2:DatasetTDB2 ;
    tdb2:location "/fuseki-base/databases/query" ;
    # The default-graph view is the UNION of the base fq: graph + every per-edit
    # named graph (the writer's changefiles, PUT to /query/data?graph=...), so a
    # plain `fq:contains` query (no GRAPH clause) sees authored edits layered on
    # the base. Drop an edit's named graph to revert it.
    tdb2:unionDefaultGraph true .
