@prefix ceonm: <http://w3id.org/CEON/ontology/material/> .
@prefix ceonp: <http://w3id.org/CEON/ontology/product/> .
@prefix ceonpo: <http://w3id.org/CEON/ontology/processODP/> .
@prefix ceonpr: <http://w3id.org/CEON/ontology/process/> .
@prefix ceonq: <http://w3id.org/CEON/ontology/quantity/> .
@prefix ceonr: <http://w3id.org/CEON/ontology/resourceODP/> .
@prefix ceonst: <http://w3id.org/CEON/ontology/statement/> .
@prefix dqv: <http://www.w3.org/ns/dqv#> .
@prefix emmo: <https://w3id.org/emmo#> .
@prefix futuram: <https://www.purl.org/futuram#> .
@prefix iofcore: <https://spec.industrialontologies.org/ontology/core/Core/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dqv:hasQualityMeasurement a owl:ObjectProperty ;
    rdfs:label "has quality measurement"@en ;
    rdfs:comment "Links a CompositionStatement to a data-quality measurement (DQV)."@en ;
    rdfs:range dqv:QualityMeasurement ;
    owl:inverseOf dqv:computedOn .

dqv:inDimension a owl:ObjectProperty ;
    rdfs:label "in dimension"@en ;
    rdfs:comment "Links a metric to the quality dimension it belongs to."@en ;
    rdfs:domain dqv:Metric ;
    rdfs:range dqv:Dimension .

dqv:isMeasurementOf a owl:ObjectProperty ;
    rdfs:label "is measurement of"@en ;
    rdfs:comment "Links a quality measurement to the metric it observes."@en ;
    rdfs:domain dqv:QualityMeasurement ;
    rdfs:range dqv:Metric .

dqv:value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:comment "The numeric score computed by a quality metric (FutuRaM uses a 0–3 scale per dimension)."@en ;
    rdfs:domain dqv:QualityMeasurement ;
    rdfs:range xsd:double .

prov:wasAttributedTo a owl:ObjectProperty ;
    rdfs:label "was attributed to"@en ;
    rdfs:comment "Attributes the composition statement to the prov:Agent (person or organisation) responsible for asserting it — i.e. who told you this. Standard PROV-O term, declared here for documentation."@en ;
    rdfs:domain prov:Entity ;
    rdfs:range prov:Agent .

prov:hadPrimarySource a owl:ObjectProperty ;
    rdfs:label "had primary source"@en ;
    rdfs:comment "Links the composition statement to the PRIMARY source (a futuram:Source / prov:Entity) the stated value was taken from. Revives the legacy provenance predicate (prov:hadPrimarySource, a specialisation of prov:wasDerivedFrom for the originating source). Standard PROV-O term."@en ;
    rdfs:domain prov:Entity ;
    rdfs:range prov:Entity ;
    rdfs:subPropertyOf prov:wasDerivedFrom .

dcterms:rights a owl:AnnotationProperty ;
    rdfs:label "rights"@en ;
    rdfs:comment "Licensing / usage rights of the composition statement's data (e.g. \"CC BY-ND\"). Revives the legacy dcterms:rights annotation."@en .

skos:note a owl:AnnotationProperty ;
    rdfs:label "note"@en ;
    rdfs:comment "A free-text note qualifying the composition statement (provenance caveats, assumptions). Revives the legacy skos:note."@en .

prov:wasGeneratedBy a owl:ObjectProperty ;
    rdfs:label "was generated by"@en ;
    rdfs:comment "Links the composition statement to the prov:Activity (measurement, estimation, literature review, …) that produced it. Optional. Standard PROV-O term."@en ;
    rdfs:domain prov:Entity ;
    rdfs:range prov:Activity .

futuram:AccuracyScore a dqv:Metric ;
    rdfs:label "Accuracy Score" ;
    dqv:inDimension dqv:Accuracy .

futuram:BetaDistribution a owl:Class ;
    rdfs:label "futuram-Beta Distribution"@en ;
    rdfs:comment "Beta distribution on bounded support (natural for a mass FRACTION confined to [0,1]), shaped by futuram:alpha and futuram:beta. Requires futuram:alpha and futuram:beta. Subclass of Apollo APOLLO_SV_00000078 (alignment in apollo-futuram-bridge.ttl)."@en ;
    rdfs:subClassOf futuram:Distribution ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:CompletenessScore a dqv:Metric ;
    rdfs:label "Completeness Score" ;
    dqv:inDimension dqv:Completeness .

futuram:ConsistencyScore a dqv:Metric ;
    rdfs:label "Consistency Score" ;
    dqv:inDimension dqv:Consistency .

futuram:DrivetrainMeanStrategy a owl:NamedIndividual,
        futuram:AggregationStrategy ;
    rdfs:label "drivetrain mean (for cross-drivetrain shared component buckets)"@en ;
    rdfs:comment "The strategy of a CROSS-DRIVETRAIN shared component class that is an aggregation bucket, never a thing held in hand (e.g. elvGeneralComponents, elvCatalyticConverters): the bucket is the EQUAL mean over its DRIVETRAIN slices (elvBEV_X_Y2026, elvPetrol_X_Y2026, … average into X_Y2026). Mirrors YearSliceMeanStrategy on the DRIVETRAIN axis instead of the year axis — drivetrain is a slice dimension parallel to time. A bucket class carries this strategy INSTEAD of a measured composition statement (it is valid under the statement-or-strategy rule via the strategy), so the genuine per-drivetrain composition differences are the strategy's INPUT, not a conflict. The drivetrain leaves (elv<DT>_X_Y<year>) keep their real measured composition; only the drivetrain-free bucket is derived."@en ;
    futuram:dqvAggregation "equal-mean-per-dimension" ;
    futuram:massAggregation "equal-drivetrain-slice-mean" ;
    futuram:presentedBy "0000-0001-8569-6630" ;
    futuram:provenanceAggregation "union-of-derived-from" ;
    futuram:remainderAggregation "equal-drivetrain-slice-mean-of-unknowns" ;
    futuram:timeScopeAggregation "same-slice-only" ;
    futuram:uncertaintyAggregation "mc-resample-equal-mean-percentiles" ;
    futuram:valueAggregation "equal-drivetrain-slice-mean" .

futuram:EqualSubclassMeanStrategy a owl:NamedIndividual,
        futuram:AggregationStrategy ;
    rdfs:label "equal subclass mean (within one time slice)"@en ;
    rdfs:comment "Product/Component aggregation WITHIN one time slice: a leaf class is the EQUAL (unweighted) mean of its instances' composition-statement trees; a parent class is the EQUAL (unweighted) mean of its direct subclasses — each subclass counts once, and only subclasses of the SAME time scope participate. The strategy of every derived ancestor year-slice (e.g. an electric-car 2026 slice)."@en ;
    futuram:dqvAggregation "equal-mean-per-dimension" ;
    futuram:massAggregation "sum-of-part-masses" ;
    futuram:presentedBy "0000-0001-8569-6630" ;
    futuram:provenanceAggregation "union-of-derived-from" ;
    futuram:remainderAggregation "equal-subclass-mean-of-unknowns" ;
    futuram:timeScopeAggregation "same-slice-only" ;
    futuram:uncertaintyAggregation "mc-resample-equal-mean-percentiles" ;
    futuram:valueAggregation "equal-subclass-mean" .

futuram:GammaDistribution a owl:Class ;
    rdfs:label "futuram-Gamma Distribution"@en ;
    rdfs:comment "Gamma distribution (positive, right-skewed), shaped by futuram:shapeParam (k) and futuram:scaleParam (theta). Requires futuram:shapeParam and futuram:scaleParam. Subclass of Apollo APOLLO_SV_00000255 (alignment in apollo-futuram-bridge.ttl)."@en ;
    rdfs:subClassOf futuram:Distribution ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:IntegrityScore a dqv:Metric ;
    rdfs:label "Integrity Score" ;
    dqv:inDimension dqv:Integrity .

futuram:LogNormalDistribution a owl:Class ;
    rdfs:label "futuram-Log-Normal Distribution"@en ;
    rdfs:comment "Log-normal distribution (positive, right-skewed) for strictly positive concentrations with multiplicative uncertainty: the interval's best value is the median (scale), futuram:logStdDev is the standard deviation in log space. Requires futuram:logStdDev (plus the interval's best value as median). Subclass of Apollo APOLLO_SV_00000254 (alignment in apollo-futuram-bridge.ttl)."@en ;
    rdfs:subClassOf futuram:Distribution ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:MassWeightedRollupStrategy a owl:NamedIndividual,
        futuram:AggregationStrategy ;
    rdfs:label "mass-weighted subclass rollup (materials)"@en ;
    rdfs:comment "Material-family aggregation: a material superclass (e.g. a copper-alloys family) is the MASS-WEIGHTED combination of the leaf materials under it (rdfs:subClassOf rollup with min/max bounds), through every layer up to futuram:Material. Materials are time-independent."@en ;
    futuram:dqvAggregation "mass-weighted-mean-per-dimension" ;
    futuram:massAggregation "not-applicable-materials" ;
    futuram:presentedBy "0000-0001-8569-6630" ;
    futuram:provenanceAggregation "union-of-derived-from" ;
    futuram:remainderAggregation "mass-weighted-rollup-of-unknowns" ;
    futuram:timeScopeAggregation "time-independent" ;
    futuram:uncertaintyAggregation "mass-weighted-minmax-bounds" ;
    futuram:valueAggregation "mass-weighted-subclass-rollup" .

futuram:NormalDistribution a owl:Class ;
    rdfs:label "futuram-Normal Distribution"@en ;
    rdfs:comment "Normal (Gaussian) distribution: MEAN is the interval's best value, standard deviation is futuram:stdDev. Requires futuram:stdDev (plus the interval's best value as mean). Subclass of Apollo APOLLO_SV_00000036 (alignment in apollo-futuram-bridge.ttl)."@en ;
    rdfs:subClassOf futuram:Distribution ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:Source a owl:Class ;
    rdfs:label "futuram-Source"@en ;
    rdfs:comment "A source a composition statement was derived from — a document, dataset, datasheet, standard or measurement record. A prov:Entity (alignment in prov-futuram-bridge.ttl), referenced from a statement via prov:hadPrimarySource and described with dcterms (title, bibliographicCitation, source)."@en ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:TimeScopedClass a owl:Class ;
    rdfs:label "futuram-Time Scoped Class"@en ;
    rdfs:comment "METACLASS (punning, intentional): its members are class nodes that carry exactly one of futuram:referenceYear or futuram:hasReferencePeriod — the time slices of the Product/Component families. The fq: serving layer exposes composition amounts for Product/Component-level classes ONLY when they are time-scoped (a timeless base is served solely as its declared year-slice average, marked as such)."@en ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:TimelinessScore a dqv:Metric ;
    rdfs:label "Timeliness Score" ;
    dqv:inDimension dqv:Timeliness .

futuram:TriangularDistribution a owl:Class ;
    rdfs:label "futuram-Triangular Distribution"@en ;
    rdfs:comment "Triangular distribution: the interval's best value is the MODE, and futuram:lowerBound / futuram:upperBound are the two bounds. Requires futuram:lowerBound and futuram:upperBound (plus the interval's best value as mode). Subclass of Apollo APOLLO_SV_00000081 (alignment in apollo-futuram-bridge.ttl)."@en ;
    rdfs:subClassOf futuram:Distribution ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:UniformDistribution a owl:Class ;
    rdfs:label "futuram-Uniform Distribution"@en ;
    rdfs:comment "Continuous uniform distribution: every value in [lowerBound, upperBound] is equally likely (the best value is the midpoint, informational). Requires futuram:lowerBound and futuram:upperBound. Subclass of Apollo APOLLO_SV_00000257 (continuous uniform distribution; alignment in apollo-futuram-bridge.ttl)."@en ;
    rdfs:subClassOf futuram:Distribution ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:RectangularDistribution a owl:Class ;
    rdfs:label "futuram-Rectangular Distribution"@en ;
    rdfs:comment "A continuous uniform (rectangular) distribution parameterised by a single RELATIVE half-width, futuram:uncertaintyLimit, symmetric about the quantity's best value: the support is [best x (1 - limit), best x (1 + limit)]. The form the FutuRaM reference dataset uses for every measured value (the source generator's note: 'we use a X% rectangular distribution'): a data-quality / confidence judgement gives a defensible +/- band, and the rectangular (maximum-entropy) distribution is the honest model when only a range is known (GUM type-B). It carries ONE scale parameter (the half-width) instead of futuram:UniformDistribution's two explicit endpoints (lowerBound/upperBound) -- those endpoints are DERIVED (best x (1 -/+ limit)), not stored. Its standard deviation is limit x best / sqrt(3) (the sigma of a uniform of half-width a is a/sqrt(3)) -- the source's stored uncertainty% (a relative sigma). Modelled as a continuous uniform (Apollo APOLLO_SV_00000257; alignment in apollo-futuram-bridge.ttl) and a futuram:Distribution; NOT a subclass of futuram:UniformDistribution, so it does not inherit that class's lowerBound/upperBound requirement (it parameterises the SAME family differently)."@en ;
    rdfs:subClassOf futuram:Distribution ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:uncertaintyLimitStrategy a owl:ObjectProperty ;
    rdfs:label "uncertainty-limit strategy"@en ;
    rdfs:comment "Declares HOW a futuram:RectangularDistribution's half-width is DERIVED from the composition statement's data-quality indicators, by IRI: a futuram:UncertaintyRuleset (e.g. futuram:FuturamDQS) whose weighted-sum-of-dimensions + limit bands compute the rectangular uncertaintyLimit from the six DQ scores. The distribution stores NO numeric scale -- only this strategy and the DQ scores are ground truth; the limit, its standard deviation (limit/sqrt(3)) and the interval endpoints (best x (1 -/+ limit)) are all derived by applying the strategy. Mirrors how futuram:hasAggregationStrategy declares HOW a class's composition is derived rather than storing it."@en ;
    rdfs:domain futuram:RectangularDistribution ;
    rdfs:range futuram:UncertaintyRuleset ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:uncertaintyLimit a owl:DatatypeProperty ;
    rdfs:label "uncertainty limit"@en ;
    rdfs:comment "The RELATIVE half-width of a futuram:RectangularDistribution (a fraction, e.g. 0.30 = +/-30 %), such that the true value lies uniformly in best x [1 - limit, 1 + limit]. NOT stored on measured statements -- it is DERIVED from the data-quality indicators by the distribution's futuram:uncertaintyLimitStrategy (a weighted sum of the six DQ dimensions banded to a limit; Integrity down-weighted, Timeliness up-weighted, reproducing the FutuRaM reference dataset's hand-authored per-material limit on its source table). Retained as a property for the derived view / for a statement that wishes to assert a limit directly. Everything else follows: relative standard deviation = limit / sqrt(3) (the served fq:relativeUncertainty), interval endpoints best x (1 -/+ limit). Dimensionless."@en ;
    rdfs:domain futuram:RectangularDistribution ;
    rdfs:range xsd:double ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:ValidityScore a dqv:Metric ;
    rdfs:label "Validity Score" ;
    dqv:inDimension dqv:Validity .

futuram:WeibullDistribution a owl:Class ;
    rdfs:label "futuram-Weibull Distribution"@en ;
    rdfs:comment "Weibull distribution, shaped by futuram:shapeParam (k) and futuram:scaleParam (lambda). Requires futuram:shapeParam and futuram:scaleParam. Subclass of Apollo APOLLO_SV_00000256 (alignment in apollo-futuram-bridge.ttl)."@en ;
    rdfs:subClassOf futuram:Distribution ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:YearSliceMeanStrategy a owl:NamedIndividual,
        futuram:AggregationStrategy ;
    rdfs:label "year-slice mean (default for timeless base classes)"@en ;
    rdfs:comment "The DEFAULT strategy of a timeless Product/Component BASE class: the base is always the EQUAL mean over its own time slices (e.g. the 2026 and 2027 slices of one product class average into the base). This is the ONLY cross-year aggregation in the model, and it is explicit: a base served under this strategy carries the derived reference period (span of its slices) and the strategy link, never a silent pool. Keeps bases valid under the statement-or-strategy rule."@en ;
    futuram:dqvAggregation "equal-mean-per-dimension" ;
    futuram:massAggregation "equal-year-slice-mean" ;
    futuram:presentedBy "0000-0001-8569-6630" ;
    futuram:provenanceAggregation "union-of-derived-from" ;
    futuram:remainderAggregation "equal-year-slice-mean-of-unknowns" ;
    futuram:timeScopeAggregation "span-of-slices" ;
    futuram:uncertaintyAggregation "mc-resample-equal-mean-percentiles" ;
    futuram:valueAggregation "equal-year-slice-mean" .

futuram:alpha a owl:DatatypeProperty ;
    rdfs:label "alpha"@en ;
    rdfs:comment "The first shape parameter (alpha) of a beta distribution. Strictly positive, dimensionless."@en ;
    rdfs:domain futuram:Distribution ;
    rdfs:range xsd:double ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:beta a owl:DatatypeProperty ;
    rdfs:label "beta"@en ;
    rdfs:comment "The second shape parameter (beta) of a beta distribution. Strictly positive, dimensionless."@en ;
    rdfs:domain futuram:Distribution ;
    rdfs:range xsd:double ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:dqvAggregation a owl:DatatypeProperty ;
    rdfs:label "DQV aggregation"@en ;
    rdfs:comment "How the children's DQV quality measurements (per-dimension scores) aggregate to class level. DECLARED rule; the resolver does not yet materialise class-level DQV measurements."@en ;
    rdfs:domain futuram:AggregationStrategy ;
    rdfs:range xsd:string ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasBestValue a owl:ObjectProperty ;
    rdfs:label "has best value"@en ;
    rdfs:comment "The central best point estimate of a quantity interval — the single representative value (a qudt:QuantityValue with numericValue and unit). REQUIRED on every interval, so a statement always carries one representative number; the included min/max endpoints (the spread) are OPTIONAL. The Monte-Carlo aggregator centres each statement's sampled distribution on this best value, using the min/max endpoints as the spread and the stated distribution kind (futuram:hasDistribution) as the shape; with no min/max it treats the statement as a point (delta). CEON's QuantityInterval has no central/best/nominal value term (only interval endpoints), so this is a FutuRaM addition reusing the same QUDT value pattern. Neutral as to which statistic it is (mean, median or mode); it is the value to use when one number is needed."@en ;
    rdfs:domain ceonq:QuantityInterval ;
    rdfs:range qudt:QuantityValue ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasComposition a owl:ObjectProperty ;
    rdfs:label "has composition"@en ;
    rdfs:comment "Class-level ontological part-of: instances of the subject class are composed of instances of the object class. Inferred from the instance composition statements (whole's class hasComposition part's class), not asserted directly. Relates a Product/Component/Material class to a Product/Component/Material/Element class."@en ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasDistribution a owl:ObjectProperty ;
    rdfs:label "has distribution"@en ;
    rdfs:comment "The probability-distribution the Monte-Carlo aggregator samples this quantity interval from — a futuram:Distribution (subclass of the Apollo continuous parametric probability distribution) carrying the shape parameters its kind requires. Required: a quantity IS a distribution, so its shape is mandatory. Pairs with futuram:hasBestValue (the centre); the interval min/max endpoints remain an optional informational spread."@en ;
    rdfs:domain ceonq:QuantityInterval ;
    rdfs:range futuram:Distribution ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasPart a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has part"@en ;
    rdfs:comment "The whole has the given constituent as a (possibly indirect) part. NOT asserted but entailed: the property chain (hasCompositionStatement o hasPartRelation o refersTo) derives the direct edge from each composition statement's qualified relations, and transitivity closes the rest. Specialises the transitive ceon:resourceODP:hasPart."@en ;
    rdfs:domain ceonr:Constituent ;
    rdfs:range ceonr:Constituent ;
    owl:inverseOf futuram:partOf ;
    owl:propertyChainAxiom ( futuram:hasCompositionStatement futuram:hasPartRelation futuram:refersTo ) ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasDirectPart a owl:ObjectProperty ;
    rdfs:label "has direct part"@en ;
    rdfs:comment "The IMMEDIATE (one-step) whole->part relation between two components, deliberately NON-transitive: it builds the component-granularity hierarchy one level at a time (componentKeyLevel0 -> Level1 -> ... in the source data). A sub-property of the transitive futuram:hasPart (every direct part is a part), so transitive reach is still available via hasPart while the layer definitions (Main/Sub/SubSub/SubSubSubComponent) quantify over this direct relation and stay level-clean. Mirrors EMMO's split between hasPart (transitive) and hasDirectPart (non-transitive)."@en ;
    rdfs:domain ceonr:Constituent ;
    rdfs:range ceonr:Constituent ;
    rdfs:subPropertyOf futuram:hasPart ;
    owl:inverseOf futuram:isDirectPartOf ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:isDirectPartOf a owl:ObjectProperty ;
    rdfs:label "is direct part of"@en ;
    rdfs:comment "Inverse of futuram:hasDirectPart: the immediate whole a component is a direct part of. The component-layer definitions are written over this direction so the layering is entailed TOP-DOWN from the MainComponent seed (a direct part of a MainComponent is a SubComponent, and so on)."@en ;
    rdfs:domain ceonr:Constituent ;
    rdfs:range ceonr:Constituent ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasProduction a owl:ObjectProperty ;
    rdfs:label "has production"@en ;
    rdfs:comment "The transformation process by which the constituent this composition statement refers to was created / produced — e.g. a CEON ManufacturingProcess, ProductionProcess or AssemblingProcess (casting, moulding, sewing, welding, assembly). Optional, so statements where it does not apply (e.g. an element inherent in a material) may omit it."@en ;
    rdfs:domain futuram:PartRelation ;
    rdfs:range ceonpo:Process ;
    rdfs:seeAlso ceonpr:ManufacturingProcess,
        iofcore:ManufacturingProcess ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasQuantity a owl:ObjectProperty ;
    rdfs:label "has quantity"@en ;
    rdfs:comment "The amount of the constituent, as a CEON QuantityInterval (a required best estimate via futuram:hasBestValue, plus optional included min/max endpoints, each a qudt:QuantityValue). The min/max bounds, when present, carry the SPREAD of the value. On a CompositionStatement it is the measured amount; on a ClassCompositionStatement it is the aggregated amount (best value = central percentile, endpoints = the Monte-Carlo distribution's percentile bounds)."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( futuram:PartRelation futuram:ClassCompositionStatement ) ] ;
    rdfs:range ceonq:QuantityInterval ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasRecycling a owl:ObjectProperty ;
    rdfs:label "has recycling"@en ;
    rdfs:comment "The transformation process by which the constituent this composition statement refers to is recovered / recycled at end of life — e.g. a CEON RecycleProcess, DismantleProcess, DisassemblingProcess, RefurbishmentProcess or ReuseProcess. Optional."@en ;
    rdfs:domain futuram:PartRelation ;
    rdfs:range ceonpo:Process ;
    rdfs:seeAlso ceonpr:RecycleProcess ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasReferencePeriod a owl:AnnotationProperty ;
    rdfs:label "has reference period"@en ;
    rdfs:comment "The reference / production PERIOD qualifying a product (or component) time-slice CLASS, e.g. a 2025-2030 small-car class. Ranges over a W3C Time time:Interval bounded by time:hasBeginning / time:hasEnd — deliberately the SAME pattern as futuram:hasValidityPeriod (statement valid-time), applied at class level; no bespoke start/end literal properties. CEON's availableStartDate/availableEndDate were considered and rejected: they are statement-level transaction-time (data availability), not class valid-time. A time-based class carries EXACTLY ONE of futuram:referenceYear or futuram:hasReferencePeriod."@en ;
    rdfs:range time:Interval ;
    rdfs:seeAlso futuram:hasValidityPeriod,
        futuram:referenceYear ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:itemMass a owl:ObjectProperty ;
    rdfs:label "item mass"@en ;
    rdfs:comment "The absolute mass of ONE item of a Product/Component, as a QUDT quantity value in kilograms (e.g. one V0301030105 weighs ~1450 kg). The REFERENCE ANCHOR that turns the otherwise purely fractional (kg/kg) composition into absolute amounts: the absolute mass of a constituent in a whole = itemMass(whole) x its kg/kg composition fraction. Composition math itself stays kg/kg and is unaffected; itemMass plays no part in mass conservation. Carried per INSTANCE as a measured fact; the CLASS-level value is DERIVED, resolving exactly like a composition statement — a measured instance value wins, otherwise the class's futuram:hasAggregationStrategy derives it via the strategy's futuram:massAggregation facet (mean over slices/subclasses, or sum over composition parts). Restricted to Product/Component (countable items); Material and Element have no item mass because matter is bulk, measured per kilogram, never counted."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( futuram:Product futuram:Component ) ] ;
    rdfs:range qudt:QuantityValue ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:logStdDev a owl:DatatypeProperty ;
    rdfs:label "log standard deviation"@en ;
    rdfs:comment "The standard deviation in LOG space of a log-normal distribution (the sigma of ln X), the median being the quantity's best value. Dimensionless."@en ;
    rdfs:domain futuram:Distribution ;
    rdfs:range xsd:double ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:lowerBound a owl:DatatypeProperty ;
    rdfs:label "lower bound"@en ;
    rdfs:comment "The lower bound (support minimum) of a bounded distribution — the lower vertex of a triangular distribution or the lower limit of a uniform distribution. In the same fraction unit as the quantity's best value."@en ;
    rdfs:domain futuram:Distribution ;
    rdfs:range xsd:double ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:massAggregation a owl:DatatypeProperty ;
    rdfs:label "mass aggregation"@en ;
    rdfs:comment "How the children's item masses (futuram:itemMass, the absolute kg of a whole) combine to the class-level item mass. Controlled token; the rdfs:comment on each strategy individual states the exact rule. Two directions occur and the token selects between them: 'sum-of-part-masses' for the parts->whole composition direction (a whole's mass is the sum of its constituent parts' masses), and 'equal-subclass-mean' / 'equal-year-slice-mean' / 'equal-drivetrain-slice-mean' for the slice/drivetrain/subclass->base direction (a base/bucket's mass is the mean of its slices' masses). itemMass resolves like a composition statement: a measured instance value wins; an absent value is derived by this facet. Mass aggregation is mean-or-sum, decided here on the strategy IRI, never hard-coded in code."@en ;
    rdfs:domain futuram:AggregationStrategy ;
    rdfs:range xsd:string ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:massConserved a owl:DatatypeProperty ;
    rdfs:label "mass conserved"@en ;
    rdfs:comment "Derived verdict on a WHOLE constituent: false iff its part composition statements necessarily OVERSHOOT its own mass (the sum of the minimum part masses exceeds the maximum mass of the whole), which is physically impossible. Absent / true means no overshoot was detected (a shortfall is permitted and not flagged). Materialised by the mass-conservation SPARQL rule and checked by SHACL."@en ;
    rdfs:domain ceonr:Constituent ;
    rdfs:range xsd:boolean ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:pathCoverage a owl:DatatypeProperty ;
    rdfs:label "path coverage"@en ;
    rdfs:comment "Fraction (0..1) of the contributing part-of paths that had a complete chain of composition statements and were therefore included in the aggregation. Below 1 means the aggregated quantity is a coverage-flagged lower bound (incomplete paths were excluded). Mirrored as a DQV Completeness measurement."@en ;
    rdfs:domain futuram:ClassCompositionStatement ;
    rdfs:range xsd:double ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:presentedBy a owl:AnnotationProperty ;
    rdfs:label "presented by"@en ;
    rdfs:comment "ORCID (or other identifier) of the person who presented / authored the term."@en .

futuram:provenanceAggregation a owl:DatatypeProperty ;
    rdfs:label "provenance aggregation"@en ;
    rdfs:comment "How PROV lineage aggregates: which sources/agents/activities the derived ClassCompositionStatement records."@en ;
    rdfs:domain futuram:AggregationStrategy ;
    rdfs:range xsd:string ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:remainderAggregation a owl:DatatypeProperty ;
    rdfs:label "remainder aggregation"@en ;
    rdfs:comment "How the unattributed remainder (coverage / unknown* placeholders) rolls up to class level."@en ;
    rdfs:domain futuram:AggregationStrategy ;
    rdfs:range xsd:string ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:scaleParam a owl:DatatypeProperty ;
    rdfs:label "scale parameter"@en ;
    rdfs:comment "The scale parameter (theta for gamma, lambda for Weibull) of a gamma or Weibull distribution. Strictly positive, in the same fraction unit as the best value."@en ;
    rdfs:domain futuram:Distribution ;
    rdfs:range xsd:double ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:shapeParam a owl:DatatypeProperty ;
    rdfs:label "shape parameter"@en ;
    rdfs:comment "The shape parameter (k) of a gamma or Weibull distribution. Strictly positive, dimensionless."@en ;
    rdfs:domain futuram:Distribution ;
    rdfs:range xsd:double ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:sliceAxis a owl:AnnotationProperty ;
    rdfs:label "slice axis" ;
    rdfs:comment "The AGGREGATION AXIS a futuram:sliceOf edge runs along, identified by the futuram:AggregationStrategy IRI that combines that dimension (futuram:YearSliceMeanStrategy for the year axis, futuram:DrivetrainMeanStrategy for the drivetrain axis). The strategy IRI IS the axis identity — there is no per-axis predicate." ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:sliceOf a owl:AnnotationProperty ;
    rdfs:label "slice of" ;
    rdfs:comment "Links a slice class (a year/period slice, a drivetrain variant, …) to the PARENT class it slices along one aggregation axis. Generic over every axis; the axis is named by futuram:sliceAxis. An annotation between punned class nodes — deliberately NOT rdfs:subClassOf (the slice additionally IS rdfs:subClassOf its parent, asserted separately; sliceOf alone never feeds the subclass-based aggregation). A class may be sliceOf more than one parent when it slices along more than one axis." ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:statementPartClass a owl:ObjectProperty ;
    rdfs:label "statement part class"@en ;
    rdfs:comment "The constituent CLASS the aggregated quantity is about (e.g. futuram:Copper). Sub-property of ceon:statementAbout. The class analogue of futuram:statementPart."@en ;
    rdfs:domain futuram:ClassCompositionStatement ;
    rdfs:range owl:Class ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:PartRelation a owl:Class ;
    rdfs:label "part relation"@en ;
    rdfs:comment "A qualified relation between a CompositionStatement (about a whole) and ONE of its constituents. Carries the measured amount (ceon:hasQuantityInterval) and per-edge metadata (contentHash, quality) for that single part, and points at the shared part individual via futuram:refersTo. Deliberately NOT a ceon:Constituent: CEON's Constituent is a non-recursive leaf (not a PhysicalObject, cannot itself have constituents), whereas the part a PartRelation refers to (e.g. a motor) is a full PhysicalObject that is a whole elsewhere in the recursive composition tree. The qualified relation lets the same shared part carry per-edge data without being collapsed into the edge."@en ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:fillerPart a owl:ObjectProperty ;
    rdfs:label "filler part"@en ;
    rdfs:comment "INTERNAL rule-to-rule channel: a bare whole->part structural edge that complete-chains.rq synthesises between unknown* fillers (whole -> unknownComponent -> unknownMaterial -> part), with NO quantity and NOT wrapped in a CompositionStatement/PartRelation. The class lift (infer-class-composition.rq) reads it as a level-adjacent structural edge so a coarse measurement still reaches the class view one step at a time. Replaces the retired bare futuram:statementPart this channel used before the qualified-relation reshape."@en ;
    rdfs:domain ceonr:Constituent ;
    rdfs:range ceonr:Constituent ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasPartRelation a owl:ObjectProperty ;
    rdfs:label "has part relation"@en ;
    rdfs:comment "Links a CompositionStatement (about a whole, a ceon:Composition) to one of its qualified PartRelations — one per constituent child. The grouping predicate that lets a single statement carry the whole's full composition (N parts) as N qualified relations. The futuram analogue of ceon:hasConstituent, but ranging over a recursive qualified relation rather than CEON's non-recursive Constituent leaf."@en ;
    rdfs:domain futuram:CompositionStatement ;
    rdfs:range futuram:PartRelation ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:refersTo a owl:ObjectProperty ;
    rdfs:label "refers to"@en ;
    rdfs:comment "The constituent (product/component/material/element individual) a PartRelation is about — the CHILD of the composition, a shared and recursively-decomposable individual. Revives the legacy futuram:refersTo (sub-property of emmo:refersTo, 300 uses in the legacy data). Replaces the rewrite's statementPart. CEON has no Constituent->resource pointer, so emmo:refersTo fills the gap."@en ;
    rdfs:domain futuram:PartRelation ;
    rdfs:range ceonr:Constituent ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:contentHash a owl:DatatypeProperty ;
    rdfs:label "content hash"@en ;
    rdfs:comment "Content-addressed identity of a PartRelation — sha1(source|whole|part|best|lo|hi|unit). Stamped by the identity plugin on every relation (skolemized or author-named) so dedup, MC-cache keys and conflict detection key on the hash literal, not the node IRI. The 1:1-with-edge identity the per-whole grouped statement node no longer provides."@en ;
    rdfs:domain futuram:PartRelation ;
    rdfs:range xsd:string ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:statementWholeClass a owl:ObjectProperty ;
    rdfs:label "statement whole class"@en ;
    rdfs:comment "The whole of a class composition statement: the product/component/material CLASS whose aggregated composition is being stated (e.g. futuram:SmallCar). Sub-property of ceon:statementAbout. The class analogue of futuram:statementWhole, which ranges over an instance."@en ;
    rdfs:domain futuram:ClassCompositionStatement ;
    rdfs:range owl:Class ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:stdDev a owl:DatatypeProperty ;
    rdfs:label "standard deviation"@en ;
    rdfs:comment "The standard deviation of a normal distribution (the mean being the quantity's best value). In the same fraction unit as the best value. cf. Apollo 'standard deviation'."@en ;
    rdfs:domain futuram:Distribution ;
    rdfs:range xsd:double ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:timeScopeAggregation a owl:DatatypeProperty ;
    rdfs:label "time scope aggregation"@en ;
    rdfs:comment "How the children's reference years/periods determine the aggregate's time scope (same-slice-only, span-of-slices, or time-independent)."@en ;
    rdfs:domain futuram:AggregationStrategy ;
    rdfs:range xsd:string ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:uncertaintyAggregation a owl:DatatypeProperty ;
    rdfs:label "uncertainty aggregation"@en ;
    rdfs:comment "How the uncertainty (interval bounds / Monte-Carlo distributions) of the children aggregates."@en ;
    rdfs:domain futuram:AggregationStrategy ;
    rdfs:range xsd:string ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:unknownComponent a owl:Class ;
    rdfs:label "futuram-unknownComponent" ;
    rdfs:comment "A generic placeholder component standing in for the unattributed remainder of a coarse (level-skipping) composition statement, so the bounded amount can be carried down a full structural chain. Not a measured constituent."@en ;
    rdfs:subClassOf futuram:Component ;
    futuram:hasAggregationStrategy futuram:RemainderStrategy ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:unknownElement a owl:Class ;
    rdfs:label "futuram-unknownElement"@en ;
    rdfs:comment "A generic placeholder element standing in for the unattributed remainder of a material's element content (the part of a material's mass not located to a named element). A constituent (ceon:Constituent). Mirrors unknownComponent/unknownMaterial at the element level. Not a measured element."@en ;
    rdfs:subClassOf futuram:Element ;
    futuram:hasAggregationStrategy futuram:RemainderStrategy .

futuram:unknownMaterial a owl:Class ;
    rdfs:label "futuram-unknownMaterial" ;
    rdfs:comment "A generic placeholder material standing in for the unattributed remainder of a coarse (level-skipping) composition statement, so the bounded amount can be carried down a full structural chain. Not a measured constituent."@en ;
    rdfs:subClassOf futuram:Material ;
    futuram:hasAggregationStrategy futuram:RemainderStrategy ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:unknownProduct a owl:Class ;
    rdfs:label "futuram-unknownProduct"@en ;
    rdfs:comment "A generic placeholder (sub-)product standing in for the unattributed remainder of a coarse (level-skipping) composition statement whose unnamed structural filler is itself a product. A constituent (ceon:Constituent). Completes the unknown* set with unknownComponent / unknownMaterial / unknownElement. Not a measured product."@en ;
    rdfs:subClassOf futuram:Product ;
    futuram:hasAggregationStrategy futuram:RemainderStrategy .

futuram:upperBound a owl:DatatypeProperty ;
    rdfs:label "upper bound"@en ;
    rdfs:comment "The upper bound (support maximum) of a bounded distribution — the upper vertex of a triangular distribution or the upper limit of a uniform distribution. In the same fraction unit as the quantity's best value."@en ;
    rdfs:domain futuram:Distribution ;
    rdfs:range xsd:double ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:validFrom a owl:DatatypeProperty ;
    rdfs:label "valid from"@en ;
    rdfs:comment "Datatype shortcut for the start of the statement's validity period (inclusive), when only the calendar date matters. For a fully described interval (with time:Instant endpoints, open ends, or sub-day precision) use futuram:hasValidityPeriod over a time:Interval instead."@en ;
    rdfs:domain futuram:CompositionStatement ;
    rdfs:range xsd:date ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:validUntil a owl:DatatypeProperty ;
    rdfs:label "valid until"@en ;
    rdfs:comment "Datatype shortcut for the end of the statement's validity period (inclusive). Omit for an open-ended (still-valid) statement. See futuram:hasValidityPeriod for the fully described interval form."@en ;
    rdfs:domain futuram:CompositionStatement ;
    rdfs:range xsd:date ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:valueAggregation a owl:DatatypeProperty ;
    rdfs:label "value aggregation"@en ;
    rdfs:comment "How the central (best) composition values of the children aggregate. Controlled token; the rdfs:comment on each strategy individual states the exact rule."@en ;
    rdfs:domain futuram:AggregationStrategy ;
    rdfs:range xsd:string ;
    futuram:presentedBy "0000-0001-8569-6630" .

<https://www.purl.org/futuram/composition-statement> a owl:Ontology ;
    rdfs:label "FutuRaM Composition Statement Ontology (CEON-aligned)"@en ;
    rdfs:comment """FutuRaM composition-statement model, rebuilt on top of the Circular Economy Ontology Network (CEON) instead of re-inventing a parallel statement layer.

The model is layered, following CEON's own split between structure and assertion:
  * Structural backbone — a composed thing hasComposition a ceon:Composition, and that Composition compositionOf a constituent (sub-product, component, material or element). This reuses CEON's native product-composition ODP and replaces the former bare futuram:hasPart.
  * Measured statement — futuram:CompositionStatement specialises ceon:ProductCompositionStatement (itself a ceon:Statement, i.e. a reified prov:Entity). The statement is attached to the ceon:Composition node (Composition futuram:hasCompositionStatement statement); since the Composition already names the constituent via compositionOf, the statement is unambiguously about that constituent without a separate link. It carries the measured amount via ceon:hasQuantityInterval over a ceon:QuantityInterval whose endpoints are QUDT quantity values (qudt:QuantityValue with qudt:numericValue and qudt:unit), plus metrological uncertainty. This is the layer that carries concrete values, interval bounds, uncertainty and provenance — none of which the bare ceon:compositionQuantity (a flat xsd:double) can hold. Validation and availability of the statement reuse ceon:hasValidation / ceon:hasAvailability.

FutuRaM-specific extensions that CEON does not provide are added in the futuram namespace and aligned under CEON where a parent exists:
  * the two circular-economy transformations of the constituent (hasProduction / hasRecycling) over CEON Process;
  * data-quality measurements via W3C DQV.

TBox only — no instance data. CEON, QUDT, EMMO and CHEBI terms are referenced by IRI and not redefined here."""@en .

dqv:Accuracy a dqv:Dimension ;
    rdfs:label "Accuracy"@en .

dqv:Completeness a dqv:Dimension ;
    rdfs:label "Completeness"@en .

dqv:Consistency a dqv:Dimension ;
    rdfs:label "Consistency"@en .

dqv:Integrity a dqv:Dimension ;
    rdfs:label "Integrity"@en .

dqv:Timeliness a dqv:Dimension ;
    rdfs:label "Timeliness"@en .

dqv:Validity a dqv:Dimension ;
    rdfs:label "Validity"@en .

futuram:hasAggregationStrategy a owl:ObjectProperty ;
    rdfs:label "has aggregation strategy"@en ;
    rdfs:comment "Attaches an AggregationStrategy to the CLASS, not the instance (punning — fine in RDF/SHACL). A class with a declared strategy is a valid composition source even when statement-less: its composition comes via aggregation. Distinguishes 'intentionally statement-less' from 'accidentally incomplete data'."@en ;
    rdfs:domain owl:Class ;
    rdfs:range futuram:AggregationStrategy ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:hasValidityPeriod a owl:ObjectProperty ;
    rdfs:label "has validity period"@en ;
    rdfs:comment "The real-world time interval (valid-time) over which the composition asserted by this statement holds. Ranges over a W3C Time time:Interval bounded by time:hasBeginning / time:hasEnd. Distinct from futuram:referenceYear (a class annotation) and from CEON's availableStartDate/availableEndDate (data availability / transaction-time)."@en ;
    rdfs:domain futuram:CompositionStatement ;
    rdfs:range time:Interval ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:partOf a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "part of"@en ;
    rdfs:comment "The whole that this instance is a (possibly indirect) part of — e.g. copper partOf motor, motor partOf clio, and (by transitivity) copper partOf clio. Inverse of futuram:hasPart and of the undeclared inverse of ceon:resourceODP:hasPart. For a part specific to one whole this equals, at each step, the whole of the composition statement the part appears in; the iterative product context is the transitive closure."@en ;
    rdfs:domain ceonr:Constituent ;
    rdfs:range ceonr:Constituent ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:referenceYear a owl:AnnotationProperty ;
    rdfs:label "reference year"@en ;
    rdfs:comment "The reference / production year qualifying a product (or component) CLASS, e.g. a 2026 small-car class. The year is a property of the class an instance is typed into, not of the instance or the statement itself."@en ;
    rdfs:range xsd:int .

futuram:Element a owl:Class ;
    rdfs:label "futuram-Element" ;
    rdfs:comment "A chemical element that a material is composed of. A constituent (ceon:Constituent), so it is a valid compositionOf target. Mass-based. External alignment (ChEBI/CEON/EMMO parents) in the *-futuram-bridge.ttl files."@en ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:Material a owl:Class ;
    rdfs:label "futuram-Material" ;
    rdfs:comment "A material that a component is composed of; composed of elements. A constituent (ceon:Constituent), so it is a valid compositionOf target. Mass-based."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf ( [ a owl:Restriction ;
                        owl:onProperty futuram:hasCompositionStatement ;
                        owl:someValuesFrom futuram:CompositionStatement ] [ a owl:Restriction ;
                        owl:onProperty futuram:memberOfStrategyClass ;
                        owl:someValuesFrom futuram:AggregationStrategy ] ) ] ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:TimeBasedClassFamily a owl:Class ;
    rdfs:label "futuram-Time Based Class Family"@en ;
    rdfs:comment "METACLASS (punning, intentional): its members are the level-root classes whose concrete subclasses must be TIME SLICES (futuram:referenceYear xor futuram:hasReferencePeriod) to carry composition amounts. Asserted on futuram:Product and futuram:Component ONLY; futuram:Material and futuram:Element are time-independent and deliberately not members. SHACL reads this membership instead of hard-coding the two families. Deliberately a CLASS MEMBERSHIP, not a boolean annotation: a bare boolean literal in the data path triggers owlrl's literal-identity collision (Python True == 1.0 merges 'true' with quantity values of exactly 1.0 during RDFS closure)."@en ;
    futuram:presentedBy "0000-0001-8569-6630" .

dqv:QualityMeasurement a owl:Class ;
    rdfs:label "Quality Measurement"@en ;
    rdfs:comment "Represents the evaluation of a given resource against a specific quality metric."@en .

futuram:Component a owl:Class,
        futuram:TimeBasedClassFamily ;
    rdfs:label "futuram-Component" ;
    rdfs:comment "A (sub-)part of a product; itself composed of materials or further components. A constituent of the thing it is part of (ceon:Constituent), so it is a valid compositionOf target. Mass-based."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf ( [ a owl:Restriction ;
                        owl:onProperty futuram:hasCompositionStatement ;
                        owl:someValuesFrom futuram:CompositionStatement ] [ a owl:Restriction ;
                        owl:onProperty futuram:memberOfStrategyClass ;
                        owl:someValuesFrom futuram:AggregationStrategy ] ) ] ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:Product a owl:Class,
        futuram:TimeBasedClassFamily ;
    rdfs:label "futuram-Product" ;
    rdfs:comment "A product whose composition is described by composition statements. A product may itself be a constituent of a larger product (sub-product), hence also a ceon:Constituent. Mass-based."@en ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf ( [ a owl:Restriction ;
                        owl:onProperty futuram:hasCompositionStatement ;
                        owl:someValuesFrom futuram:CompositionStatement ] [ a owl:Restriction ;
                        owl:onProperty futuram:memberOfStrategyClass ;
                        owl:someValuesFrom futuram:AggregationStrategy ] ) ] ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:memberOfStrategyClass a owl:ObjectProperty ;
    rdfs:label "member of strategy class"@en ;
    rdfs:comment "Documentation-only helper: instance -> the AggregationStrategy of a class it is typed into, defined by the property chain (rdf:type o hasAggregationStrategy). OWL Full because of the punning and the rdf:type link in the chain — no DL reasoner is expected to compute it; it exists so the validity rule below is statable as an owl:unionOf axiom. SHACL (S2) is the enforcement."@en ;
    rdfs:range futuram:AggregationStrategy ;
    owl:propertyChainAxiom ( rdf:type futuram:hasAggregationStrategy ) ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:ClassCompositionStatement a owl:Class ;
    rdfs:label "futuram-Class Composition Statement"@en ;
    rdfs:comment "An aggregated composition statement whose whole is a product/component/material CLASS rather than an instance: it states how much of a constituent a member of that class contains, computed by rolling up the instance composition statements (transitive mass aggregation, with Monte-Carlo uncertainty propagation). Derived, not measured: it records prov:wasDerivedFrom the source instance statements and a DQV Completeness/coverage score. CEON parent (ceonst:ProductCompositionStatement) aligned in ceon-futuram-bridge.ttl."@en ;
    skos:definition "The aggregated composition of a class of products/components/materials in terms of a constituent, derived from the instance-level composition statements of its members."@en ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:RemainderStrategy a owl:NamedIndividual,
        futuram:AggregationStrategy ;
    rdfs:label "remainder (unknown* placeholders)"@en ;
    rdfs:comment "The strategy of the unknown* placeholder classes and the per-context minted unknown holders: their 'composition' IS the residual — the coarse (level-skipping) bound minus the granular attribution — recomputed per queried scope, never measured. Time scope and provenance are inherited from the whole the remainder belongs to."@en ;
    futuram:dqvAggregation "inherited-from-coarse-statement" ;
    futuram:massAggregation "inherited-from-whole" ;
    futuram:presentedBy "0000-0001-8569-6630" ;
    futuram:provenanceAggregation "derived-from-coarse-statement" ;
    futuram:remainderAggregation "is-remainder" ;
    futuram:timeScopeAggregation "inherited-from-whole" ;
    futuram:uncertaintyAggregation "coarse-bound-propagation" ;
    futuram:valueAggregation "coarse-minus-granular-residual" .

futuram:hasCompositionStatement a owl:ObjectProperty ;
    rdfs:label "futuram-hasCompositionStatement" ;
    rdfs:comment "Links the whole (a concrete product, component or material individual) to its per-whole CompositionStatement, which groups all of the whole's constituents as qualified part-relations. Sub-property of ceon:hasComposition (CEON's whole->composition link); revives the legacy futuram:hasCompositionStatement direction. Its inverse is ceon:compositionOf (composition->whole)."@en ;
    rdfs:domain ceonr:Constituent ;
    rdfs:range futuram:CompositionStatement ;
    futuram:presentedBy "0000-0001-8569-6630" .

dqv:Dimension a owl:Class ;
    rdfs:label "Dimension"@en ;
    rdfs:comment "Represents criteria relevant for assessing quality."@en .

dqv:Metric a owl:Class ;
    rdfs:label "Metric"@en ;
    rdfs:comment "A standard against which a quality measurement is taken."@en .

futuram:CompositionStatement a owl:Class ;
    rdfs:label "futuram-Composition Statement" ;
    rdfs:comment "A FutuRaM specialisation of the CEON Product Composition Statement AND a ceon:Composition: the per-whole node that GROUPS the whole's constituents. The whole links to it via ceon:hasComposition; it links back via ceon:compositionOf; and it carries one futuram:PartRelation per constituent (futuram:hasPartRelation), each PartRelation holding that part's measured quantity and per-edge metadata. Being a ceon:Statement it is already a prov:Entity, describable with PROV-O. (Reshaped from the former per-(whole,part) statement: it is now per-WHOLE, grouping N qualified part-relations.)"@en ;
    skos:definition "The composed information of a product, component or material — the grouping of its constituents, each a qualified part-relation carrying a measured quantity (with optional interval bounds)."@en ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:Distribution a owl:Class ;
    rdfs:label "futuram-Distribution"@en ;
    rdfs:comment "The probability-distribution a Monte-Carlo sampler draws a composition statement's value from. Subclass of the Apollo Structured Vocabulary 'continuous parametric probability distribution' (APOLLO_SV_00000251). A distribution is samplable only with its SHAPE (the class) plus the PARAMETERS that shape requires: the centre is the interval's futuram:hasBestValue, and the remaining shape parameters are carried on this distribution node by the futuram parameter properties (futuram:lowerBound, futuram:upperBound, futuram:stdDev, futuram:logStdDev, futuram:alpha, futuram:beta, futuram:shapeParam, futuram:scaleParam). Each named subclass states which parameters it requires; SHACL enforces them per kind. Apollo parent (APOLLO_SV_00000251) aligned in apollo-futuram-bridge.ttl."@en ;
    futuram:presentedBy "0000-0001-8569-6630" .

futuram:AggregationStrategy a owl:Class ;
    rdfs:label "futuram-Aggregation Strategy"@en ;
    rdfs:comment "A way a class-level composition is DERIVED instead of measured. Attached to the CLASS (punned node) via futuram:hasAggregationStrategy — aggregation is class-level in this model (futuram:ClassCompositionStatement already has a class as its whole). Each named individual MUST declare all seven facet properties (SHACL S3): futuram:valueAggregation, uncertaintyAggregation, dqvAggregation, remainderAggregation, provenanceAggregation, timeScopeAggregation, massAggregation."@en ;
    futuram:presentedBy "0000-0001-8569-6630" .

[] a owl:AllDisjointClasses ;
    owl:members ( futuram:Product futuram:Component futuram:Material futuram:Element ) .

