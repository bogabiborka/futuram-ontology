futuram:constructionMinerals a owl:Class ;
    rdfs:label "futuram-constructionMinerals" ;
    rdfs:subClassOf futuram:Minerals ;
    futuram:hasAggregationStrategy futuram:MassWeightedRollupStrategy .

futuram:ferrousMetals a owl:Class ;
    rdfs:label "futuram-Ferrous metals" ;
    rdfs:subClassOf futuram:Material ;
    futuram:hasAggregationStrategy futuram:MassWeightedRollupStrategy .

futuram:nonCuAndAlAlloys a owl:Class ;
    rdfs:label "futuram-nonCuAndAlAlloys" ;
    rdfs:subClassOf futuram:non-ferrousMetals ;
    futuram:hasAggregationStrategy futuram:MassWeightedRollupStrategy .

[] a owl:AllDisjointClasses ;
    owl:members ( futuram:elvGeneralComponents futuram:elvEmbeddedElectronics futuram:elvDepollutionComponents ) .

# The four component-granularity layers are pairwise disjoint (Table 2): a
# component sits at exactly one layer. With the equivalentClass (hasPart some
# <next layer>) definitions above, this disjointness is what enforces the level
# separation under reasoning (an individual cannot be both a MainComponent and a
# SubComponent).
[] a owl:AllDisjointClasses ;
    owl:members ( futuram:MainComponent futuram:SubComponent futuram:SubSubComponent futuram:SubSubSubComponent ) .

