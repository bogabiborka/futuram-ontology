#################################################################
#
#    Component-granularity backbone
#
#    Source: the ELV ETL CSVs (componentKeyLevel0 -> componentKeyLevel1). The
#    top-level component keys are the MainComponents; the futuram:hasDirectPart
#    edges carry the one-step nesting to their direct sub-parts, the
#    SubComponents. Layer membership is asserted from the source keys (so it is
#    materialised without a reasoner) AND backed by the layer definitions above,
#    which a description-logic reasoner uses to verify the layering top-down from
#    the MainComponent seed.
#
#    Only classes that ALREADY exist in this taxonomy are typed here; no new
#    concrete component class is introduced (introducing one would make the ETL
#    instantiate it and diverge from the frozen reference outputs). Source keys
#    that are NOT declared classes are therefore not part of the backbone:
#      - elvEVspecific / elvEVspecificOther  (not declared; ETL routes them
#        elsewhere) -> their L0->L1 edge is omitted;
#      - elvRest  (a level remainder / catch-all, mapped to the unknown filler by
#        the ETL) -> not a MainComponent.
#    The depollution Main uses the canonical two-'l' spelling
#    (futuram:elvDepollutionComponents); the source's one-'l' key is aliased to it
#    by the ETL.
#
#    The source component hierarchy is two levels deep, so the two deeper layer
#    classes (SubSubComponent / SubSubSubComponent) are declared but unpopulated.
#
#################################################################

# MainComponents (source componentKeyLevel0), with hasDirectPart edges to their
# declared SubComponents.
futuram:elvGeneralComponents a futuram:MainComponent .

futuram:elvDepollutionComponents a futuram:MainComponent ;
    futuram:hasDirectPart futuram:elvCatalyticConverters .

futuram:elvEmbeddedElectronics a futuram:MainComponent ;
    futuram:hasDirectPart futuram:elvEmbeddedElectronicsActuators,
        futuram:elvEmbeddedElectronicsCables,
        futuram:elvEmbeddedElectronicsControllers,
        futuram:elvEmbeddedElectronicsHeadlights,
        futuram:elvPowerElectronics .

# SubComponents (source componentKeyLevel1) — all already-declared classes.
# elvElectricMotor is a SubComponent in the source (under the EV-specific branch);
# that branch is not a declared class, so it is typed as a SubComponent without a
# MainComponent hasDirectPart parent.
futuram:elvCatalyticConverters a futuram:SubComponent .
futuram:elvElectricMotor a futuram:SubComponent .
futuram:elvEmbeddedElectronicsActuators a futuram:SubComponent .
futuram:elvEmbeddedElectronicsCables a futuram:SubComponent .
futuram:elvEmbeddedElectronicsControllers a futuram:SubComponent .
futuram:elvEmbeddedElectronicsHeadlights a futuram:SubComponent .
futuram:elvPowerElectronics a futuram:SubComponent .

