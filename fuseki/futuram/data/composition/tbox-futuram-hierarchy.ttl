futuram:SubComponent a owl:Class ;
    rdfs:label "futuram-SubComponent" ;
    rdfs:comment "Second component-granularity level (componentKeyLevel1 in the source data): a Component that is a direct part of a MainComponent. Defined (equivalentClass) so the layer is ENTAILED top-down from the MainComponent seed via isDirectPartOf, not asserted by hand. Disjoint from the other three component layers."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( futuram:Component
                    [ a owl:Restriction ;
                        owl:onProperty futuram:isDirectPartOf ;
                        owl:someValuesFrom futuram:MainComponent ] ) ] ;
    rdfs:subClassOf futuram:Component ;
    futuram:hasAggregationStrategy futuram:YearSliceMeanStrategy .

futuram:SubSubComponent a owl:Class ;
    rdfs:label "futuram-SubSubComponent" ;
    rdfs:comment "Third component-granularity level: a Component that is a direct part of a SubComponent. Defined (equivalentClass), entailed top-down via isDirectPartOf. Declared for schema stability; UNPOPULATED in the current ELV source data, whose component hierarchy is two levels deep (Main/Sub only). Disjoint from the other three component layers."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( futuram:Component
                    [ a owl:Restriction ;
                        owl:onProperty futuram:isDirectPartOf ;
                        owl:someValuesFrom futuram:SubComponent ] ) ] ;
    rdfs:subClassOf futuram:Component ;
    futuram:hasAggregationStrategy futuram:YearSliceMeanStrategy .

futuram:SubSubSubComponent a owl:Class ;
    rdfs:label "futuram-SubSubSubComponent" ;
    rdfs:comment "Fourth (deepest) component-granularity level: a Component that is a direct part of a SubSubComponent. Defined (equivalentClass), entailed top-down via isDirectPartOf. Declared for schema stability; UNPOPULATED in the current ELV source data. Disjoint from the other three component layers."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( futuram:Component
                    [ a owl:Restriction ;
                        owl:onProperty futuram:isDirectPartOf ;
                        owl:someValuesFrom futuram:SubSubComponent ] ) ] ;
    rdfs:subClassOf futuram:Component ;
    futuram:hasAggregationStrategy futuram:YearSliceMeanStrategy .

