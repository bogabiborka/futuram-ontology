# Bulk source data — fetch on demand with scripts/download_zenodo.py.
# (The small sample workbook src/etl/input/example/*.xlsx stays tracked.)
src/etl/input/futuram/*.csv
data/*.csv

# Vendored external generator repo (git submodule / embedded clone, 120MB+):
# the R source generator MattRoess/VehicleComposition. Reference only, not built.
external/

# Downloaded / extracted upstream ontology sources (fetched on demand, regenerable).
# The chebi .gz + the tracked tbox/abox stay; the pulled-in source dirs do not.
ontology/sources/apollo-sv/
# emmo.ttl is the self-contained vendored EMMO the consistency check needs in CI;
# it is committed (the deploy-data workflow fails fast without it).
ontology/sources/iof-core/
ontology/sources/qudt/
ontology/sources/skos/
ontology/sources/stato/
ontology/sources/w3c-time/

# Large archives (the unpacked contents are tracked / regenerable; the zip is not).
*.zip
ontology.zip

# TBox-term availability cache (scripts/check_tbox_term_availability.py, regenerable).
.cache/


# Bench loose run logs / live recheck artifacts (regenerated each run).
bench/_query_logs/
bench/_recheck.live/
bench/_recheck*.zip
bench/_live_archive/



# Decompressed ChEBI core: regenerated from the tracked .gz by
# scripts/extract_chebi_module.sh. The .gz stays tracked; the 345MB .owl does not.
ontology/sources/chebi/chebi_core.owl

# Baked triplestores / Fuseki runtime databases.
**/databases/


# Python & tooling caches.
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.venv/

# Secrets / local env (keep the .env.example template tracked).
.env
**/.env

# macOS.
.DS_Store

# Optional ROBOT consistency-check merged artifacts (input-full.owl / output-full.ttl)
consistency/build/

# Bench run artifacts — regenerated every run, not source.
#   *.zip   compressed per-run transcripts
#   *.live/ loose live transcripts the harness flushes mid-run (observer reads these)
bench/transcripts*.zip
bench/transcripts*.live/
bench/*results*.json

# (bench/futuram_void*.ttl is a tracked, committed artifact — NOT ignored, so the
#  host-side helpers have a VoID to read on a fresh checkout.)

# Next.js observer app — dependencies & build output (regenerate with npm install).
bench/observer/node_modules/
bench/observer/.next/
bench/observer/out/
bench/observer/next-env.d.ts

# Regenerable ground-truth artifacts — all DERIVED from the tracked source
# (scenario YAMLs + the oracle/ETL), so they are not committed. Regenerate with:
#   tests/scenarios.py            -> tests/fixtures/*.ttl
#   scripts/freeze_oracle.py      -> tests/expected/<version>/*.json
#   scripts/gen_sample.py         -> ontology/abox/example/sample-instances.ttl
#   csv_to_rdf.py (from the CSV)  -> src/etl/input/test/26-onecar-real.yaml
# (The served futuram datasource — fuseki/futuram/data/{composition,query} — IS
#  committed: it's the tracked full-CSV ETL output regenerated by
#  tests/build_instances.py futuram.)
tests/fixtures/
tests/expected/
ontology/abox/example/sample-instances.ttl
src/etl/input/test/26-onecar-real.yaml
bench/.caffeinate.pid

# Transient runtime / large external / scratch artifacts (not source):
# pidfiles + run logs
logs/
# benchmark run outputs (regenerable) — except all-in-1, which the viewer publishes
bench/experiments/*
!bench/experiments/all-in-1/
# live transcript dirs the observer streams into (run_bench output)
bench/live/
bench/ask-live/
# remembered ad-hoc ask runs (per-ask folders, regenerable)
bench/asks/

